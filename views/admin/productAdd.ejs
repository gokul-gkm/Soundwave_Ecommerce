<%- include('../layout/adminlayout.ejs') -%>
<link rel="stylesheet" href="/css/admin/productAdd.css" />

<div class="container-scroller">
  <%- include('../layout/adminnav.ejs') -%>
  <div class="main-panel">
    <div class="content-wrapper" style="padding: 1.5rem 2rem; position: relative;">
      
      <!-- Decorative Background Blurs -->
      <div class="position-absolute" style="background-color: rebeccapurple; filter: blur(140px); width: 14rem; height: 14rem; border-radius: 50%; right: 5rem; top: 10rem; z-index: 0; pointer-events: none;"></div>
      <div class="position-absolute" style="background-color: rgba(0, 0, 255, 0.4); filter: blur(140px); width: 14rem; height: 14rem; border-radius: 50%; left: 10rem; bottom: 5rem; z-index: 0; pointer-events: none;"></div>

      <!-- Header -->
      <div class="pa-page-header" style="position: relative; z-index: 1;">
        <div>
          <a href="/admin/products" class="pa-btn-back mb-2">
            <i class="mdi mdi-arrow-left"></i> Back to Products
          </a>
          <h3 class="pa-page-title">Add New Product</h3>
          <p class="pa-page-subtitle">Fill in the details to list a new product in the store.</p>
        </div>
      </div>

      <form id="productForm" action="/admin/products" method="post" enctype="multipart/form-data" style="position: relative; z-index: 1;">
        <div class="row">
          
          <!-- Left Column (Main Details) -->
          <div class="col-lg-8">
            
            <!-- Basic Details Card -->
            <div class="pa-card">
              <div class="pa-card-header">
                <h5 class="pa-card-title"><i class="mdi mdi-information-outline"></i> Basic Details</h5>
              </div>
              <div class="pa-card-body">
                <div class="pa-form-group">
                  <label class="pa-form-label">Product Name *</label>
                  <input type="text" class="pa-form-control pa-val-input" name="name" id="pName" placeholder="Enter product name" required>
                  <div class="pa-error-msg" id="errName"></div>
                </div>

                <div class="pa-form-group">
                  <label class="pa-form-label">Description *</label>
                  <textarea class="pa-form-control pa-val-input" name="des" id="pDesc" placeholder="Enter a detailed product description" required></textarea>
                  <div class="pa-error-msg" id="errDesc"></div>
                </div>

                <div class="pa-form-group mb-0">
                  <label class="pa-form-label">Tags</label>
                  <input type="text" class="pa-form-control" name="tags" placeholder="e.g. wireless, headphones, gaming (comma separated)">
                </div>
              </div>
            </div>

            <!-- Pricing & Inventory Card -->
            <div class="pa-card">
              <div class="pa-card-header">
                <h5 class="pa-card-title"><i class="mdi mdi-currency-usd"></i> Pricing & Inventory</h5>
              </div>
              <div class="pa-card-body">
                <div class="row">
                  <div class="col-md-6">
                    <div class="pa-form-group">
                      <label class="pa-form-label">Price *</label>
                      <div class="pa-input-group">
                        <span class="pa-input-prefix">₹</span>
                        <input type="number" class="pa-form-control pa-val-input" name="price" id="pPrice" placeholder="0.00" min="0" required>
                      </div>
                      <div class="pa-error-msg" id="errPrice"></div>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="pa-form-group">
                      <label class="pa-form-label">Stock Quantity *</label>
                      <input type="number" class="pa-form-control pa-val-input" name="stock" id="pStock" placeholder="0" min="0" step="1" required>
                      <div class="pa-error-msg" id="errStock"></div>
                    </div>
                  </div>
                </div>

                <div class="row mt-2">
                  <div class="col-md-6">
                    <div class="pa-form-group">
                      <label class="pa-form-label">Category *</label>
                      <select class="pa-form-control" name="category" required>
                        <option value="" disabled selected>Select Category</option>
                        <% locals.categoryList.forEach(e => { %>
                          <option value="<%= e.name %>"><%= e.name %></option>
                        <% }) %>
                      </select>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="pa-form-group">
                      <label class="pa-form-label">Product Color</label>
                      <div class="pa-color-picker-wrap">
                        <input type="color" class="pa-color-input" id="pColor" name="color" value="#000000">
                        <span class="pa-color-val" id="colorValText">#000000</span>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="pa-form-group mt-3 mb-0">
                  <label class="pa-form-label">Listing Status</label>
                  <div class="pa-radio-group">
                    <label class="pa-radio-item">
                      <input type="radio" name="active" value="true" checked>
                      <span class="pa-radio-text">Active (Visible)</span>
                    </label>
                    <label class="pa-radio-item">
                      <input type="radio" name="active" value="false">
                      <span class="pa-radio-text">Inactive (Hidden)</span>
                    </label>
                  </div>
                </div>
              </div>
            </div>

          </div>

          <!-- Right Column (Images & Submit) -->
          <div class="col-lg-4">
            
            <!-- Images Card -->
            <div class="pa-card">
              <div class="pa-card-header">
                <h5 class="pa-card-title"><i class="mdi mdi-image-multiple"></i> Product Images *</h5>
              </div>
              <div class="pa-card-body">
                <p class="text-muted" style="font-size: 0.8rem; margin-bottom: 15px;">Please upload exactly 3 images (.jpg, .jpeg, .png). The first image will be the main thumbnail.</p>
                
                <div class="pa-image-grid">
                  <% for(let i=0; i<3; i++) { %>
                    <label for="imgInput<%= i %>" class="pa-image-upload-box" id="imgBox<%= i %>">
                      <input type="file" name="images" id="imgInput<%= i %>" accept="image/png, image/jpeg, image/jpg" data-index="<%= i %>" onchange="handleImage(this)">
                      <div class="pa-upload-placeholder" id="imgPlaceholder<%= i %>">
                        <i class="mdi mdi-cloud-upload-outline"></i>
                        <span>Upload <%= i === 0 ? 'Main' : `Image ${i+1}` %></span>
                      </div>
                      <img src="" class="pa-image-preview" id="imgPreview<%= i %>">
                      <div class="pa-image-overlay" id="imgOverlay<%= i %>">Replace</div>
                      <div class="pa-remove-icon" id="imgRemove<%= i %>" data-index="<%= i %>" onclick="removeImage(event, this)"><i class="mdi mdi-close"></i></div>
                    </label>
                  <% } %>
                </div>
                <div class="pa-error-msg pa-global-error" id="errImages"></div>
              </div>
            </div>

            <!-- Actions Card -->
            <div class="pa-card pa-actions-card">
              <div class="pa-card-body">
                <button type="submit" class="pa-btn-submit" id="submitBtn" disabled>
                  <i class="mdi mdi-content-save"></i> Save Product
                </button>
                <a href="/admin/products" class="pa-btn-cancel">Cancel</a>
              </div>
            </div>

          </div>

        </div>
      </form>

    </div>
  </div>
</div>

<script>
  // Elements
  const pName = document.getElementById('pName');
  const pDesc = document.getElementById('pDesc');
  const pPrice = document.getElementById('pPrice');
  const pStock = document.getElementById('pStock');
  const errName = document.getElementById('errName');
  const errDesc = document.getElementById('errDesc');
  const errPrice = document.getElementById('errPrice');
  const errStock = document.getElementById('errStock');
  const errImages = document.getElementById('errImages');
  const submitBtn = document.getElementById('submitBtn');
  const form = document.getElementById('productForm');

  // Color Picker Sync
  document.getElementById('pColor').addEventListener('input', function(e) {
    document.getElementById('colorValText').textContent = e.target.value.toUpperCase();
  });

  // Regex Patterns
  const nameRegex = /^[a-zA-Z0-9\s\-()]+$/;
  const descRegex = /^[a-zA-Z0-9\s.,:;!?()\-\/&%]+$/;

  // Validation State
  let state = { name: false, desc: false, price: false, stock: false };

  function checkFormValidity() {
    const imagesValid = Array.from({length: 3}).every((_, i) => document.getElementById(`imgInput${i}`).files.length > 0);
    if(state.name && state.desc && state.price && state.stock && imagesValid) {
      submitBtn.disabled = false;
      errImages.textContent = '';
    } else {
      submitBtn.disabled = true;
    }
  }

  // Name Validation
  pName.addEventListener('input', (e) => {
    const val = e.target.value.trim();
    if(val === '') { errName.textContent = 'Name is required.'; state.name = false; }
    else if(!nameRegex.test(val)) { errName.textContent = 'Special characters not allowed except () and -.'; state.name = false; }
    else { errName.textContent = ''; state.name = true; }
    updateInputClass(pName, state.name, val !== '');
    checkFormValidity();
  });

  // Description Validation
  pDesc.addEventListener('input', (e) => {
    const val = e.target.value.trim();
    if(val === '') { errDesc.textContent = 'Description is required.'; state.desc = false; }
    else if(!descRegex.test(val)) { errDesc.textContent = 'Invalid special characters found.'; state.desc = false; }
    else { errDesc.textContent = ''; state.desc = true; }
    updateInputClass(pDesc, state.desc, val !== '');
    checkFormValidity();
  });

  // Price Validation
  pPrice.addEventListener('input', (e) => {
    const val = parseFloat(e.target.value);
    if(isNaN(val)) { errPrice.textContent = 'Price is required.'; state.price = false; }
    else if(val < 0) { errPrice.textContent = 'Price cannot be negative.'; state.price = false; }
    else { errPrice.textContent = ''; state.price = true; }
    updateInputClass(pPrice, state.price, !isNaN(val));
    checkFormValidity();
  });

  // Stock Validation
  pStock.addEventListener('input', (e) => {
    const val = Number(e.target.value);
    if(e.target.value.trim() === '') { errStock.textContent = 'Stock is required.'; state.stock = false; }
    else if(!Number.isInteger(val)) { errStock.textContent = 'Stock must be a whole number.'; state.stock = false; }
    else if(val < 0) { errStock.textContent = 'Stock cannot be negative.'; state.stock = false; }
    else { errStock.textContent = ''; state.stock = true; }
    updateInputClass(pStock, state.stock, e.target.value.trim() !== '');
    checkFormValidity();
  });

  function updateInputClass(el, isValid, hasValue) {
    if(!hasValue) { el.classList.remove('pa-control-valid', 'pa-control-invalid'); }
    else if(isValid) { el.classList.remove('pa-control-invalid'); el.classList.add('pa-control-valid'); }
    else { el.classList.remove('pa-control-valid'); el.classList.add('pa-control-invalid'); }
  }

  // Image Handling
  function handleImage(input) {
    const index = input.dataset.index;
    const validTypes = ['image/png', 'image/jpeg', 'image/jpg'];
    if(input.files && input.files[0]) {
      if(!validTypes.includes(input.files[0].type)) {
        alert("Only PNG or JPEG images are allowed.");
        input.value = '';
        return;
      }
      const reader = new FileReader();
      reader.onload = function(e) {
        document.getElementById(`imgPreview${index}`).src = e.target.result;
        document.getElementById(`imgPreview${index}`).style.display = 'block';
        document.getElementById(`imgPlaceholder${index}`).style.display = 'none';
        document.getElementById(`imgBox${index}`).classList.add('has-image');
      }
      reader.readAsDataURL(input.files[0]);
    }
    checkFormValidity();
  }

  function removeImage(e, el) {
    e.preventDefault();
    e.stopPropagation();
    const index = el.dataset.index;
    document.getElementById(`imgInput${index}`).value = '';
    document.getElementById(`imgPreview${index}`).src = '';
    document.getElementById(`imgPreview${index}`).style.display = 'none';
    document.getElementById(`imgPlaceholder${index}`).style.display = 'flex';
    document.getElementById(`imgBox${index}`).classList.remove('has-image');
    checkFormValidity();
  }

  form.addEventListener('submit', (e) => {
    const imagesValid = Array.from({length: 3}).every((_, i) => document.getElementById(`imgInput${i}`).files.length > 0);
    if(!imagesValid) {
      e.preventDefault();
      errImages.textContent = "Please provide exactly 3 images.";
    }
  });

  // Prevent form submit on Enter
  form.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') e.preventDefault();
  });

</script>

<script src="/vendors/js/vendor.bundle.base.js"></script>
<script src="/vendors/chart.js/Chart.min.js"></script>
<script src="/vendors/progressbar.js/progressbar.min.js"></script>
<script src="/vendors/jvectormap/jquery-jvectormap.min.js"></script>
<script src="/vendors/jvectormap/jquery-jvectormap-world-mill-en.js"></script>
<script src="/js/off-canvas.js"></script>
<script src="/js/hoverable-collapse.js"></script>
<script src="/js/misc.js"></script>
<script src="/js/settings.js"></script>
<script src="/js/todolist.js"></script>
<script src="/js/dashboard.js"></script>

</body>
</html>
