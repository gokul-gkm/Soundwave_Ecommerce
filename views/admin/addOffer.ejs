<%- include('../layout/adminlayout.ejs') -%>
  <div class="container-scroller">

    <%- include('../layout/adminnav.ejs') -%>

      <link rel="stylesheet" href="/css/admin/addCategory.css">
      <div class="main-panel">
        <div class="content-wrapper">
          <div class="pa-glass-container">
            <div class="pa-glass-card">
              <% const isEdit = locals.edit ? true : false; %>
              <% const editOrCreat=locals.creat ? locals.creat : locals.edit; const name=locals.data?.name ? locals.data?.name : ''; const offer=locals.data?.offer ? locals.data?.offer : '';  %>
              <% const id=locals.id ? locals.id : null;  %>
              <h4 class="pa-card-title"><i class="mdi <%= isEdit ? 'mdi-pencil-circle-outline' : 'mdi-tag-plus' %>"></i> <%= isEdit ? 'Edit Offer' : 'Add New Offer' %></h4>

              <form class="forms-sample" action="/admin/<%=editOrCreat%>/<%=id  %>" method="post" id="myForm">
                <div class="pa-form-group">
                  <label class="pa-form-label" for="exampleInputName1"><i class="mdi mdi-format-title"></i> Offer Name</label>
                  <input value="<%=name  %>" type="text" class="pa-form-control text" oninput='checkForm()' name="name" id="exampleInputName1" placeholder="e.g. Summer Sale" required>
                  <div class="error-msg-box err" id="nameError"></div>
                </div>

                <div class="pa-form-group">
                  <label class="pa-form-label" for="offerAmount"><i class="mdi mdi-percent"></i> Offer Percentage</label>
                  <div style="position: relative; display: flex; align-items: center;">
                    <input value="<%=offer  %>" type="number" class="pa-form-control offer-val" name="offer" oninput='checkForm()' id="offerAmount" placeholder="Percentage (0-100)" min="0" max="100" required>
                    <span style="position: absolute; right: 18px; color: rgba(255,255,255,0.4); font-weight: 700;">%</span>
                  </div>
                  <div class="error-msg-box errVal" id="valError"></div>
                </div>
                  
                <div class="pa-actions">
                  <a href="/admin/offers" class="pa-btn-cancel">Cancel</a>
                  <button type="submit" id="submitBtn" class="pa-btn-submit submit"><i class="mdi mdi-check-circle-outline"></i> <%= isEdit ? 'Update Offer' : 'Save Offer' %></button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
  </div>

  <script>
   const submitBtn = document.getElementById('submitBtn');
   const textInput = document.querySelector('.text');
   const offerInput = document.querySelector('.offer-val');
   const errVal = document.querySelector('.errVal');

   function checkForm() {
       let isValid = true;
       const nameVal = textInput.value.trim();
       const offVal = offerInput.value;

       if(nameVal === '') {
           isValid = false;
       }

       if(offVal !== '') {
          if(offVal < 0 || offVal > 100) {
              isValid = false;
              errVal.textContent = 'Percentage must be between 0 and 100.';
              offerInput.style.borderColor = '#fc4b6c';
          } else {
              errVal.textContent = '';
              offerInput.style.borderColor = 'rgba(255,255,255,0.1)';
          }
       } else {
          isValid = false;
       }

       if(!isValid) {
           submitBtn.classList.add('btn-disabled');
           submitBtn.disabled = true;
       } else {
           submitBtn.classList.remove('btn-disabled');
           submitBtn.disabled = false;
       }
   }
   
   document.addEventListener('DOMContentLoaded', checkForm);
  </script>
  <script src="/vendors/js/vendor.bundle.base.js"></script>

  <script src="/vendors/chart.js/Chart.min.js"></script>
  <script src="/vendors/progressbar.js/progressbar.min.js"></script>
  <script src="/vendors/jvectormap/jquery-jvectormap.min.js"></script>
  <script src="/vendors/jvectormap/jquery-jvectormap-world-mill-en.js"></script>
  <script src="/vendors/owl-carousel-2/owl.carousel.min.js"></script>

  <script src="/js/off-canvas.js"></script>
  <script src="/js/hoverable-collapse.js"></script>
  <script src="/js/misc.js"></script>
  <script src="/js/settings.js"></script>
  <script src="/js/todolist.js"></script>
  <script src="/js/dashboard.js"></script>
  <style>
    body::-webkit-scrollbar {
      width: 0;
    }

    body {
      overflow: hidden !important;
    }

    .container-scroller {
      overflow: hidden;
    }

    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
      -webkit-appearance: none !important;
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/locomotive-scroll@3.5.4/dist/locomotive-scroll.js"></script>

  <script src="https://unpkg.com/@studio-freight/lenis@1.0.33/dist/lenis.min.js"></script>

  <script src="/js/base.js"></script>

  </body>

  </html>