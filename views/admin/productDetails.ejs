<%- include('../layout/adminlayout.ejs') -%>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="background: #191c24; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
      <div class="modal-header" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
        <h5 class="modal-title"><i class="mdi mdi-delete-outline me-2" style="color: #fc4b6c;"></i>Delete Product</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center p-4">
        <div style="font-size: 3rem; color: #fc4b6c; margin-bottom: 1rem;"><i class="mdi mdi-alert-circle-outline"></i></div>
        <p style="font-size: 1.05rem;">Are you sure you want to delete this product?</p>
        <p class="text-muted" style="font-size: 0.85rem;">This action will soft-delete the product and remove all images from storage.</p>
      </div>
      <div class="modal-footer" style="border-top: 1px solid rgba(255,255,255,0.08);">
        <button type="button" class="btn btn-sm" style="background: rgba(255,255,255,0.08); color: #fff; border: 0; border-radius: 8px; padding: 8px 20px;" data-bs-dismiss="modal">Cancel</button>
        <button type="button" onclick="confirmDelete()" class="btn btn-sm" style="background: linear-gradient(135deg, #fc4b6c, #e0365b); color: #fff; border: 0; border-radius: 8px; padding: 8px 20px;" data-bs-dismiss="modal">Yes, Delete</button>
      </div>
    </div>
  </div>
</div>

<div class="container-scroller">
  <%- include('../layout/adminnav.ejs') -%>

  <div class="main-panel">
    <div class="content-wrapper" style="padding: 1.5rem 2rem;">

      <!-- Decorative Background Blurs -->
      <div class="circle position-fixed" style="background-color: rebeccapurple; filter: blur(136px); width: 13rem; height: 10rem; border-radius: 50%; right: 5rem; top: 20rem; z-index: 0; pointer-events: none;"></div>
      <div class="circle position-fixed" style="background-color: rgba(0, 0, 255, 0.589); filter: blur(136px); width: 13rem; height: 10rem; border-radius: 50%; left: 15rem; top: 5rem; z-index: 0; pointer-events: none;"></div>

      <!-- Page Header -->
      <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3" style="position: relative; z-index: 1;">
        <div class="d-flex align-items-center gap-3">
          <a href="/admin/products" class="pd-back-btn"><i class="mdi mdi-arrow-left"></i></a>
          <div>
            <h3 style="margin: 0; font-weight: 700; font-size: 1.4rem;">Product Details</h3>
            <p style="margin: 0; color: rgba(255,255,255,0.5); font-size: 0.82rem;">
              ID: <span style="color: #8854d0; font-weight: 600;"><%= product._id %></span>
            </p>
          </div>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <div class="pd-status-badge pd-status-<%= product.listed ? 'listed' : 'unlisted' %>" id="listingBadge">
            <i class="mdi mdi-<%= product.listed ? 'check-circle' : 'close-circle' %>"></i>
            <%= product.listed ? 'Listed' : 'Unlisted' %>
          </div>
          <button class="pd-action-btn pd-action-toggle" id="toggleBtn" onclick="toggleListing('<%= product._id %>')">
            <i class="mdi mdi-<%= product.listed ? 'eye-off' : 'eye' %>"></i>
            <%= product.listed ? 'Unlist' : 'List' %>
          </button>
          <button class="pd-action-btn pd-action-delete" data-bs-toggle="modal" data-bs-target="#deleteModal">
            <i class="mdi mdi-delete-outline"></i> Delete
          </button>
        </div>
      </div>

      <div class="row" style="position: relative; z-index: 1;">

        <!-- LEFT COLUMN -->
        <div class="col-lg-8">

          <!-- Image Gallery -->
          <div class="pd-card mb-4">
            <div class="pd-card-header">
              <h5><i class="mdi mdi-image-multiple me-2"></i>Product Images</h5>
              <span class="pd-badge-count"><%= product.images.length %> image<%= product.images.length > 1 ? 's' : '' %></span>
            </div>
            <div class="pd-card-body">
              <div class="pd-gallery">
                <div class="pd-gallery-main" id="mainImageWrap">
                  <% if (product.images.length > 0) { %>
                  <img id="mainImage" src="<%= product.images[0].startsWith('http') ? product.images[0] : '/productImage/' + product.images[0] %>" alt="<%= product.name %>" />
                  <% } else { %>
                  <div class="pd-no-image"><i class="mdi mdi-image-off"></i><span>No Image</span></div>
                  <% } %>
                </div>
                <% if (product.images.length > 1) { %>
                <div class="pd-gallery-thumbs">
                  <% product.images.forEach((img, i) => { %>
                  <div class="pd-thumb <%= i === 0 ? 'pd-thumb-active' : '' %>" onclick="setMainImage(this, '<%= img  %>')">
                    <img src="<%= img.startsWith('http') ? img : '/productImage/' + img %>" alt="Thumbnail <%= i + 1 %>" />
                  </div>
                  <% }) %>
                </div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Product Information -->
          <div class="pd-card mb-4">
            <div class="pd-card-header">
              <h5><i class="mdi mdi-information-outline me-2"></i>Product Information</h5>
            </div>
            <div class="pd-card-body">
              <h4 class="pd-product-title"><%= product.name %></h4>
              <div class="pd-description">
                <p><%= product.description %></p>
              </div>

              <div class="pd-info-grid">
                <div class="pd-info-card">
                  <div class="pd-info-icon" style="background: rgba(0, 210, 91, 0.1); color: #00d25b;">
                    <i class="mdi mdi-currency-inr"></i>
                  </div>
                  <div>
                    <span class="pd-info-label">Selling Price</span>
                    <span class="pd-info-value">₹<%= product.price.toFixed(2) %></span>
                  </div>
                </div>
                <% if (product.actualPrice && product.actualPrice !== product.price) { %>
                <div class="pd-info-card">
                  <div class="pd-info-icon" style="background: rgba(246, 168, 33, 0.1); color: #f6a821;">
                    <i class="mdi mdi-tag-outline"></i>
                  </div>
                  <div>
                    <span class="pd-info-label">Original Price</span>
                    <span class="pd-info-value" style="text-decoration: line-through; opacity: 0.6;">₹<%= product.actualPrice.toFixed(2) %></span>
                  </div>
                </div>
                <% } %>
                <div class="pd-info-card">
                  <div class="pd-info-icon" style="background: rgba(0, 143, 251, 0.1); color: #008ffb;">
                    <i class="mdi mdi-package-variant"></i>
                  </div>
                  <div>
                    <span class="pd-info-label">Stock</span>
                    <span class="pd-info-value <%= product.stock <= 5 ? 'pd-low-stock' : '' %>">
                      <%= product.stock %> units
                      <% if (product.stock <= 5 && product.stock > 0) { %><span class="pd-stock-warn">Low</span><% } %>
                      <% if (product.stock === 0) { %><span class="pd-stock-out">Out of Stock</span><% } %>
                    </span>
                  </div>
                </div>
                <div class="pd-info-card">
                  <div class="pd-info-icon" style="background: rgba(110, 66, 193, 0.1); color: #8854d0;">
                    <i class="mdi mdi-shape-outline"></i>
                  </div>
                  <div>
                    <span class="pd-info-label">Category</span>
                    <span class="pd-info-value"><%= product.category ? product.category.name : 'N/A' %></span>
                  </div>
                </div>
                <% if (product.color) { %>
                <div class="pd-info-card">
                  <div class="pd-info-icon" style="background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.7);">
                    <i class="mdi mdi-palette-outline"></i>
                  </div>
                  <div>
                    <span class="pd-info-label">Color</span>
                    <span class="pd-info-value d-flex align-items-center gap-2">
                      <span class="pd-color-dot" data-color="<%= product.color %>"></span>
                      <%= product.color %>
                    </span>
                  </div>
                </div>
                <% } %>
                <div class="pd-info-card">
                  <div class="pd-info-icon" style="background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.7);">
                    <i class="mdi mdi-calendar"></i>
                  </div>
                  <div>
                    <span class="pd-info-label">Created At</span>
                    <span class="pd-info-value"><%= product.createdAt || 'N/A' %></span>
                  </div>
                </div>
              </div>

              <!-- Tags -->
              <% if (product.tags && product.tags.length > 0 && product.tags[0] !== '') { %>
              <div class="pd-tags-section">
                <span class="pd-info-label" style="margin-bottom: 8px; display: block;">Tags</span>
                <div class="pd-tags">
                  <% product.tags.forEach(tag => { %>
                  <span class="pd-tag"><%= tag %></span>
                  <% }) %>
                </div>
              </div>
              <% } %>
            </div>
          </div>

          <!-- Reviews Section -->
          <div class="pd-card mb-4">
            <div class="pd-card-header">
              <h5><i class="mdi mdi-star-outline me-2"></i>Customer Reviews</h5>
              <span class="pd-badge-count"><%= reviews.length %> review<%= reviews.length !== 1 ? 's' : '' %></span>
            </div>
            <div class="pd-card-body">
              <% if (reviews.length > 0) { %>
                <% 
                  const avgRating = (reviews.reduce((sum, r) => sum + r.ratings, 0) / reviews.length).toFixed(1);
                %>
                <!-- Average Rating -->
                <div class="pd-avg-rating">
                  <div class="pd-avg-number"><%= avgRating %></div>
                  <div>
                    <div class="pd-stars">
                      <% for (let s = 1; s <= 5; s++) { %>
                        <i class="mdi mdi-star<%= s <= Math.round(avgRating) ? '' : '-outline' %>" style="color: #f6a821;"></i>
                      <% } %>
                    </div>
                    <span class="pd-avg-label">Based on <%= reviews.length %> review<%= reviews.length !== 1 ? 's' : '' %></span>
                  </div>
                </div>
                <div class="pd-reviews-list">
                  <% reviews.forEach(review => { %>
                  <div class="pd-review-item">
                    <div class="pd-review-header">
                      <div class="pd-review-user">
                        <div class="pd-review-avatar"><%= review.userId ? review.userId.name.charAt(0).toUpperCase() : '?' %></div>
                        <div>
                          <h6 class="pd-review-name"><%= review.userId ? review.userId.name : 'Unknown User' %></h6>
                          <div class="pd-stars pd-stars-sm">
                            <% for (let s = 1; s <= 5; s++) { %>
                              <i class="mdi mdi-star<%= s <= review.ratings ? '' : '-outline' %>" style="color: #f6a821;"></i>
                            <% } %>
                          </div>
                        </div>
                      </div>
                    </div>
                    <p class="pd-review-text"><%= review.reviews %></p>
                  </div>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="pd-empty-state">
                  <i class="mdi mdi-message-text-outline"></i>
                  <p>No reviews yet</p>
                </div>
              <% } %>
            </div>
          </div>

        </div>

        <!-- RIGHT COLUMN -->
        <div class="col-lg-4">

          <!-- Quick Stats -->
          <div class="pd-card mb-4">
            <div class="pd-card-header">
              <h5><i class="mdi mdi-chart-bar me-2"></i>Quick Stats</h5>
            </div>
            <div class="pd-card-body">
              <div class="pd-stat-row">
                <div class="pd-stat-item">
                  <div class="pd-stat-icon" style="background: linear-gradient(135deg, rgba(0,210,91,0.15), rgba(0,210,91,0.05));">
                    <i class="mdi mdi-currency-inr" style="color: #00d25b;"></i>
                  </div>
                  <div>
                    <span class="pd-stat-label">Price</span>
                    <span class="pd-stat-value">₹<%= product.price.toFixed(2) %></span>
                  </div>
                </div>
                <div class="pd-stat-item">
                  <div class="pd-stat-icon" style="background: linear-gradient(135deg, rgba(0,143,251,0.15), rgba(0,143,251,0.05));">
                    <i class="mdi mdi-package-variant" style="color: #008ffb;"></i>
                  </div>
                  <div>
                    <span class="pd-stat-label">Stock</span>
                    <span class="pd-stat-value"><%= product.stock %></span>
                  </div>
                </div>
              </div>
              <div class="pd-stat-row" style="margin-top: 12px;">
                <div class="pd-stat-item">
                  <div class="pd-stat-icon" style="background: linear-gradient(135deg, rgba(246,168,33,0.15), rgba(246,168,33,0.05));">
                    <i class="mdi mdi-star" style="color: #f6a821;"></i>
                  </div>
                  <div>
                    <span class="pd-stat-label">Avg Rating</span>
                    <span class="pd-stat-value">
                      <% if (reviews.length > 0) { %>
                        <%= (reviews.reduce((sum, r) => sum + r.ratings, 0) / reviews.length).toFixed(1) %> / 5
                      <% } else { %>
                        N/A
                      <% } %>
                    </span>
                  </div>
                </div>
                <div class="pd-stat-item">
                  <div class="pd-stat-icon" style="background: linear-gradient(135deg, rgba(110,66,193,0.15), rgba(110,66,193,0.05));">
                    <i class="mdi mdi-message-text" style="color: #8854d0;"></i>
                  </div>
                  <div>
                    <span class="pd-stat-label">Reviews</span>
                    <span class="pd-stat-value"><%= reviews.length %></span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Offer Details -->
          <div class="pd-card mb-4">
            <div class="pd-card-header">
              <h5><i class="mdi mdi-sale me-2"></i>Offer</h5>
            </div>
            <div class="pd-card-body">
              <% if (product.offer) { %>
              <div class="pd-offer-badge">
                <div class="pd-offer-icon"><i class="mdi mdi-percent"></i></div>
                <div>
                  <h6 style="margin: 0; font-weight: 600;"><%= product.offer.name %></h6>
                  <span style="color: #00d25b; font-weight: 700; font-size: 1.1rem;"><%= product.offer.offer %>% OFF</span>
                </div>
              </div>
              <% if (product.actualPrice) { %>
              <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.06);">
                <div class="pd-offer-calc">
                  <span>Original Price</span>
                  <span>₹<%= product.actualPrice.toFixed(2) %></span>
                </div>
                <div class="pd-offer-calc" style="color: #00d25b;">
                  <span>Discount (<%= product.offer.offer %>%)</span>
                  <span>-₹<%= (product.actualPrice - product.price).toFixed(2) %></span>
                </div>
                <div class="pd-offer-calc pd-offer-final">
                  <span>Final Price</span>
                  <span>₹<%= product.price.toFixed(2) %></span>
                </div>
              </div>
              <% } %>
              <% } else { %>
              <div class="pd-empty-state pd-empty-sm">
                <i class="mdi mdi-tag-off-outline"></i>
                <p>No active offer</p>
              </div>
              <% } %>
            </div>
          </div>

          <!-- Status Details -->
          <div class="pd-card mb-4">
            <div class="pd-card-header">
              <h5><i class="mdi mdi-cog-outline me-2"></i>Status</h5>
            </div>
            <div class="pd-card-body">
              <div class="pd-status-row">
                <span class="pd-status-label">Listing Status</span>
                <span class="pd-status-value" id="listStatus">
                  <i class="mdi mdi-circle pd-dot-<%= product.listed ? 'green' : 'red' %>"></i>
                  <%= product.listed ? 'Listed' : 'Unlisted' %>
                </span>
              </div>
              <div class="pd-status-row">
                <span class="pd-status-label">Active Status</span>
                <span class="pd-status-value">
                  <i class="mdi mdi-circle pd-dot-<%= product.status ? 'green' : 'red' %>"></i>
                  <%= product.status ? 'Active' : 'Inactive' %>
                </span>
              </div>
              <div class="pd-status-row">
                <span class="pd-status-label">Stock Status</span>
                <span class="pd-status-value">
                  <i class="mdi mdi-circle pd-dot-<%= product.stock > 0 ? (product.stock <= 5 ? 'yellow' : 'green') : 'red' %>"></i>
                  <%= product.stock > 0 ? (product.stock <= 5 ? 'Low Stock' : 'In Stock') : 'Out of Stock' %>
                </span>
              </div>
            </div>
          </div>

          <!-- Product ID Card -->
          <div class="pd-card mb-4">
            <div class="pd-card-header">
              <h5><i class="mdi mdi-identifier me-2"></i>Identifiers</h5>
            </div>
            <div class="pd-card-body">
              <div class="pd-id-row">
                <span class="pd-info-label">Product ID</span>
                <code class="pd-id-code"><%= product._id %></code>
              </div>
              <% if (product.category) { %>
              <div class="pd-id-row" style="margin-top: 8px;">
                <span class="pd-info-label">Category ID</span>
                <code class="pd-id-code"><%= product.category._id %></code>
              </div>
              <% } %>
              <% if (product.offer) { %>
              <div class="pd-id-row" style="margin-top: 8px;">
                <span class="pd-info-label">Offer ID</span>
                <code class="pd-id-code"><%= product.offer._id %></code>
              </div>
              <% } %>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>

<link rel="stylesheet" href="/css/admin/productDetails.css" />

<!-- Scripts -->
<script>
  // Gallery thumbnail click
  function setMainImage(thumbEl, src) {
    document.getElementById('mainImage').src = src;
    document.querySelectorAll('.pd-thumb').forEach(t => t.classList.remove('pd-thumb-active'));
    thumbEl.classList.add('pd-thumb-active');
  }

  // Apply color from data attribute
  document.querySelectorAll('.pd-color-dot[data-color]').forEach(dot => {
    dot.style.background = dot.dataset.color;
  });

  // Toggle listing
  function toggleListing(id) {
    fetch(`/admin/products/${id}/status`, {
      method: 'POST',
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ payload: id })
    })
    .then(res => res.json())
    .then(data => {
      const badge = document.getElementById('listingBadge');
      const btn = document.getElementById('toggleBtn');
      const statusText = document.getElementById('listStatus');

      if (data.updatedData.listed) {
        badge.className = 'pd-status-badge pd-status-listed';
        badge.innerHTML = '<i class="mdi mdi-check-circle"></i> Listed';
        btn.innerHTML = '<i class="mdi mdi-eye-off"></i> Unlist';
        statusText.innerHTML = '<i class="mdi mdi-circle pd-dot-green"></i> Listed';
      } else {
        badge.className = 'pd-status-badge pd-status-unlisted';
        badge.innerHTML = '<i class="mdi mdi-close-circle"></i> Unlisted';
        btn.innerHTML = '<i class="mdi mdi-eye"></i> List';
        statusText.innerHTML = '<i class="mdi mdi-circle pd-dot-red"></i> Unlisted';
      }
    });
  }

  // Delete product
  function confirmDelete() {
    fetch('/admin/products/<%= product._id %>', {
      method: 'DELETE',
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        window.location.href = '/admin/products';
      } else {
        alert('Failed to delete product');
      }
    })
    .catch(err => {
      console.error('Error:', err);
      alert('An error occurred');
    });
  }
</script>

<script src="/vendors/js/vendor.bundle.base.js"></script>
<script src="/vendors/chart.js/Chart.min.js"></script>
<script src="/vendors/progressbar.js/progressbar.min.js"></script>
<script src="/vendors/jvectormap/jquery-jvectormap.min.js"></script>
<script src="/vendors/jvectormap/jquery-jvectormap-world-mill-en.js"></script>
<script src="/vendors/owl-carousel-2/owl.carousel.min.js"></script>
<script src="/js/off-canvas.js"></script>
<script src="/js/hoverable-collapse.js"></script>
<script src="/js/misc.js"></script>
<script src="/js/settings.js"></script>
<script src="/js/todolist.js"></script>
<script src="/js/dashboard.js"></script>
<script src="/js/base.js"></script>

</body>
</html>
