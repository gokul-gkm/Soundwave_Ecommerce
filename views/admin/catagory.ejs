<%- include('../layout/adminlayout.ejs') -%>
  <div class="container-scroller">

    <%- include('../layout/adminnav.ejs') -%>

      <link rel="stylesheet" href="/css/admin/addCategory.css">
      <div class="main-panel">
        <div class="content-wrapper">
          <div class="pa-glass-container">
            <div class="pa-glass-card">
              <h4 class="pa-card-title"><i class="mdi mdi-tag-plus"></i> Add New Category</h4>

              <form class="forms-sample" action="/admin/categories" method="post" id="myForm">
                <div class="pa-form-group">
                  <label class="pa-form-label" for="exampleInputName1"><i class="mdi mdi-format-title"></i> Category Name</label>
                  <input type="text" class="pa-form-control text" oninput="category(this)" name="name" id="exampleInputName1" placeholder="Enter Category Name" required>
                  <div class="error-msg-box err" id="nameError"></div>
                </div>

                <div class="pa-form-group">
                  <label class="pa-form-label"><i class="mdi mdi-eye-outline"></i> Visibility Status</label>
                  <div class="pa-radio-group">
                    <label class="pa-radio-item">
                      <input type="radio" name="active" value="true" checked>
                      Listed
                    </label>
                    <label class="pa-radio-item">
                      <input type="radio" name="active" value="false">
                      Unlisted
                    </label>
                  </div>
                </div>

                <div class="pa-actions">
                  <a href="/admin/categories" class="pa-btn-cancel">Cancel</a>
                  <button type="submit" class="pa-btn-submit submit" id="submitBtn"><i class="mdi mdi-check-circle-outline"></i> Save Category</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
  </div>

  <script>

    const textInput = document.querySelector('.text');
    const err = document.querySelector('.err');
    const submitBtn = document.getElementById('submitBtn');
    const regex = /^[a-zA-Z-]+$/;

    function setInvalid(msg) {
      err.textContent = msg;
      textInput.style.borderColor = '#fc4b6c';
      textInput.style.boxShadow = 'inset 0 1px 2px rgba(0,0,0,0.1), 0 0 0 3px rgba(252, 75, 75, 0.15)';
      submitBtn.classList.add('btn-disabled');
      submitBtn.disabled = true;
    }

    function setValid() {
      err.textContent = '';
      textInput.style.borderColor = '#00d25b';
      textInput.style.boxShadow = 'inset 0 1px 2px rgba(0,0,0,0.1), 0 0 0 3px rgba(0, 210, 91, 0.15)';
      submitBtn.classList.remove('btn-disabled');
      submitBtn.disabled = false;
    }

    function setNeutral() {
      err.textContent = '';
      textInput.style.borderColor = 'rgba(255,255,255,0.1)';
      textInput.style.boxShadow = 'none';
      submitBtn.classList.add('btn-disabled');
      submitBtn.disabled = true;
    }

    document.getElementById('myForm').addEventListener('submit', function (e) {
      const textInputValue = textInput.value.trim();
      if (!regex.test(textInputValue)) {
        setInvalid('Category name can only contain letters and hyphens (no spaces, numbers, or symbols).');
        e.preventDefault();
      }
    });
    
    function category(e) {
      const inputValue = e.value.trim();
      
      if(inputValue.length === 0) {
        setNeutral();
        return;
      }

      fetch('/admin/categories/check', {
        method: 'POST',
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name: inputValue })
      }).then(res => res.json()).then(data => {
        
        if (data.exist === true) {
          setInvalid('There is already a category with this name.');
        } else {
          // Standard validation
          const sanitizedValue = inputValue.replace(/\d/g, '').replace(/\s/g, '-');
          if(inputValue !== sanitizedValue) {
             // Force sanitize visually
             e.value = sanitizedValue;
          }

          if (regex.test(sanitizedValue)) {
            setValid();
          } else {
            setInvalid('Category name can only contain letters and hyphens (no spaces, numbers, or symbols).');
          }
        }
      }).catch(error => {
         console.error("Error checking category", error);
      });
    }

  </script>
  <script src="/vendors/js/vendor.bundle.base.js"></script>

  <script src="/vendors/chart.js/Chart.min.js"></script>
  <script src="/vendors/progressbar.js/progressbar.min.js"></script>
  <script src="/vendors/jvectormap/jquery-jvectormap.min.js"></script>
  <script src="/vendors/jvectormap/jquery-jvectormap-world-mill-en.js"></script>
  <script src="/vendors/owl-carousel-2/owl.carousel.min.js"></script>

  <script src="/js/off-canvas.js"></script>
  <script src="/js/hoverable-collapse.js"></script>
  <script src="/js/misc.js"></script>
  <script src="/js/settings.js"></script>
  <script src="/js/todolist.js"></script>
  <script src="/js/dashboard.js"></script>
  <style>
    body::-webkit-scrollbar {
      width: 0;
    }

    body {
      overflow: hidden !important;
    }

    .container-scroller {
      overflow: hidden;
    }

    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
      -webkit-appearance: none !important;
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/locomotive-scroll@3.5.4/dist/locomotive-scroll.js"></script>

  <script src="https://unpkg.com/@studio-freight/lenis@1.0.33/dist/lenis.min.js"></script>

  <script src="/js/base.js"></script>

  </body>

  </html>