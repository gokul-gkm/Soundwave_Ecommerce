    background: rgba(0, 143, 251, 0.1);
    color: #008ffb;
    border: 1px solid rgba(0, 143, 251, 0.2);
  }
  .od-status-delivered {
    background: rgba(0, 210, 91, 0.1);
    color: #00d25b;
    border: 1px solid rgba(0, 210, 91, 0.2);
  }
  .od-status-canceled {
    background: rgba(252, 75, 75, 0.1);
    color: #fc4b6c;
    border: 1px solid rgba(252, 75, 75, 0.2);
  }
  .od-status-returned {
    background: rgba(246, 168, 33, 0.1);
    color: #f6a821;
    border: 1px solid rgba(246, 168, 33, 0.2);
  }
  .od-status-payment\ pending {
    background: rgba(246, 168, 33, 0.1);
    color: #f6a821;
    border: 1px solid rgba(246, 168, 33, 0.2);
  }

  /* Summary */
  .od-summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.65);
  }
  .od-discount-row { color: #00d25b; }
  .od-summary-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    margin: 8px 0;
  }
  .od-total-row {
    font-weight: 700;
    font-size: 1.05rem;
    color: rgba(255,255,255,0.95);
  }

  /* Customer */
  .od-customer-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .od-customer-avatar {
    width: 42px; height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6e42c1, #8854d0);
    display: flex;
    align-items: center;
    justify-content: center;
