  /* Responsive */
  @media (max-width: 768px) {
    .od-product-row {
      flex-direction: column;
      align-items: stretch;
    }
    .od-product-actions {
      flex-direction: row;
      align-items: center;
      min-width: unset;
      margin-top: 0.5rem;
    }
