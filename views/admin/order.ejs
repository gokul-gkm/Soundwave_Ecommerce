<%- include('../layout/adminlayout.ejs') -%>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

<!-- Return Accept Confirmation Modal -->
<div class="modal fade" id="staticBackdropp" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="background: #191c24; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
      <div class="modal-header" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
        <h5 class="modal-title" id="staticBackdropLabel">
          <i class="mdi mdi-package-variant-closed me-2" style="color: #6e42c1;"></i>Accept Return
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center p-4">
        <div style="font-size: 3rem; color: #f6a821; margin-bottom: 1rem;">
          <i class="mdi mdi-alert-circle-outline"></i>
        </div>
        <p style="font-size: 1.05rem;">Are you sure you want to accept this return request?</p>
        <p class="text-muted" style="font-size: 0.85rem;">This will update the product stock and process the refund if applicable.</p>
      </div>
      <div class="modal-footer" style="border-top: 1px solid rgba(255,255,255,0.08);">
        <button type="button" class="btn btn-sm" style="background: rgba(255,255,255,0.08); color: #fff; border: 0; border-radius: 8px; padding: 8px 20px;" data-bs-dismiss="modal">Cancel</button>
        <button type="button" onclick="acceptReturn()" class="btn btn-sm" style="background: linear-gradient(135deg, #6e42c1, #8854d0); color: #fff; border: 0; border-radius: 8px; padding: 8px 20px;" data-bs-dismiss="modal">Yes, Accept Return</button>
      </div>
    </div>
  </div>
</div>

<div class="container-scroller">
  <%- include('../layout/adminnav.ejs') -%>

  <div class="main-panel">
    <div class="content-wrapper" style="padding: 1.5rem 2rem;">

      <!-- Decorative Background Blurs -->
      <div class="circle position-fixed" style="background-color: rebeccapurple; filter: blur(136px); width: 13rem; height: 10rem; border-radius: 50%; right: 5rem; top: 20rem; z-index: 0; pointer-events: none;"></div>
      <div class="circle position-fixed" style="background-color: rgba(0, 0, 255, 0.589); filter: blur(136px); width: 13rem; height: 10rem; border-radius: 50%; left: 15rem; top: 5rem; z-index: 0; pointer-events: none;"></div>

      <!-- Page Header -->
      <div class="d-flex align-items-center justify-content-between mb-4" style="position: relative; z-index: 1;">
        <div class="d-flex align-items-center gap-3">
          <a href="/admin/orders" class="od-back-btn">
            <i class="mdi mdi-arrow-left"></i>
          </a>
          <div>
            <h3 style="margin: 0; font-weight: 700; font-size: 1.4rem;">Order Details</h3>
            <p style="margin: 0; color: rgba(255,255,255,0.5); font-size: 0.82rem;">
              Order ID: <span style="color: #8854d0; font-weight: 600;"><%= orderList._id %></span>
            </p>
          </div>
        </div>
        <div class="d-flex align-items-center gap-3">
          <div class="od-status-badge od-status-<%= orderList.orderStatus %>">
            <i class="mdi mdi-<%= orderList.orderStatus === 'delivered' ? 'check-circle' : orderList.orderStatus === 'canceled' ? 'close-circle' : orderList.orderStatus === 'returned' ? 'undo-variant' : orderList.orderStatus === 'shipped' ? 'truck-delivery' : 'clock-outline' %>"></i>
            <%= orderList.orderStatus.charAt(0).toUpperCase() + orderList.orderStatus.slice(1) %>
          </div>
          <span style="color: rgba(255,255,255,0.4); font-size: 0.82rem;">
            <i class="mdi mdi-calendar me-1"></i>
            <%= orderList.orderDate.toString().split(' ').slice(0, 4).join(' ') %>
          </span>
        </div>
      </div>

      <div class="row" style="position: relative; z-index: 1;">

        <!-- LEFT COLUMN -->
        <div class="col-lg-8">

          <!-- Order Items Section -->
          <div class="od-card mb-4">
            <div class="od-card-header">
              <h5><i class="mdi mdi-package-variant-closed me-2"></i>Ordered Items</h5>
              <span class="od-item-count"><%= orderList.OrderedItems.length %> item<%= orderList.OrderedItems.length > 1 ? 's' : '' %></span>
            </div>
            <div class="od-card-body">
              <% orderList.OrderedItems.forEach((product, i) => { %>
              <div class="od-product-row" id="c<%= orderList._id %>_<%= i %>">
                <div class="od-product-img-wrap">
                  <img src="<%= product.productId.images[0].startsWith('http') ? product.productId.images[0] : '/productImage/' + product.productId.images[0] %>" alt="<%= product.productId.name %>" />
                </div>
                <div class="od-product-info">
                  <h6 class="od-product-name"><%= product.productId.name %></h6>
                  <div class="od-product-meta">
                    <span><i class="mdi mdi-currency-inr"></i> <%= product.price.toFixed(2) %></span>
                    <span class="od-meta-divider">•</span>
                    <span>Qty: <strong><%= product.quantity %></strong></span>
                    <span class="od-meta-divider">•</span>
                    <span>Subtotal: <strong>₹<%= (product.price * product.quantity).toFixed(2) %></strong></span>
                  </div>

                  <!-- Cancel/Return Status -->
                  <% if (product.canceled) { %>
                  <div class="od-alert od-alert-danger mt-2">
                    <i class="mdi mdi-close-circle"></i>
                    <div>
                      <strong>Canceled by User</strong>
                      <% if (product.cancelReason) { %>
                      <p style="margin: 2px 0 0; font-size: 0.8rem; opacity: 0.85;">Reason: <%= product.cancelReason %></p>
                      <% } %>
                    </div>
                  </div>
                  <% } else if (product.returned) { %>
                  <div class="od-alert od-alert-warning mt-2">
                    <i class="mdi mdi-undo-variant"></i>
                    <div>
                      <strong>Return Requested</strong>
                      <% if (product.returnReason) { %>
                      <p style="margin: 2px 0 0; font-size: 0.8rem; opacity: 0.85;">Reason: <%= product.returnReason %></p>
                      <% } %>
                    </div>
                  </div>
                  <% } %>
                </div>

                <!-- Status Actions -->
                <div class="od-product-actions">
                  <% if (product.returned && !product.canceled) { %>
                    <% if (orderList.orderAmount !== 0 && product.orderProStatus !== 'returned') { %>
                    <button data-bs-toggle="modal" data-bs-target="#staticBackdropp" class="od-action-btn od-action-return">
                      <i class="mdi mdi-check"></i> Accept Return
                    </button>
                    <% } else { %>
                    <span class="od-status-chip od-chip-returned"><i class="mdi mdi-check-all"></i> Returned</span>
                    <% } %>
                  <% } else if (product.canceled) { %>
                    <span class="od-status-chip od-chip-canceled"><i class="mdi mdi-close"></i> Canceled</span>
                  <% } else { %>
                    <label class="od-select-label">Status</label>
                    <select id="s<%= product.productId._id %>" class="od-status-select od-select-<%= product.orderProStatus %>" onchange="orderProstatus(this,'<%= orderList._id %>','<%= product.productId._id %>')">
                      <option value="<%= product.orderProStatus %>" selected><%= product.orderProStatus.charAt(0).toUpperCase() + product.orderProStatus.slice(1) %></option>
                      <% if (product.orderProStatus !== 'shipped') { %><option value="shipped">Shipped</option><% } %>
                      <% if (product.orderProStatus !== 'delivered') { %><option value="delivered">Delivered</option><% } %>
                      <% if (product.orderProStatus !== 'canceled') { %><option value="canceled">Canceled</option><% } %>
                    </select>
                  <% } %>
                </div>
              </div>
              <% if (i < orderList.OrderedItems.length - 1) { %>
              <div class="od-divider"></div>
              <% } %>
              <% }) %>
            </div>
          </div>

        </div>

        <!-- RIGHT COLUMN -->
        <div class="col-lg-4">

          <!-- Order Summary -->
          <div class="od-card mb-4">
            <div class="od-card-header">
              <h5><i class="mdi mdi-receipt me-2"></i>Order Summary</h5>
            </div>
            <div class="od-card-body">
              <div class="od-summary-row">
                <span>Items Total</span>
                <span>₹<%= orderList.OrderedItems.reduce((sum, item) => sum + (item.price * item.quantity), 0).toFixed(2) %></span>
              </div>
              <% if (orderList.coupen) { %>
              <div class="od-summary-row od-discount-row">
                <span><i class="mdi mdi-tag-outline me-1"></i>Coupon Discount</span>
                <span style="color: #00d25b;">-<%= orderList.coupen %>%</span>
              </div>
              <% } %>
              <div class="od-summary-divider"></div>
              <div class="od-summary-row od-total-row">
                <span>Total Amount</span>
                <span>₹<%= orderList.orderAmount.toFixed(2) %></span>
              </div>
            </div>
          </div>

          <!-- Customer Info -->
          <div class="od-card mb-4">
            <div class="od-card-header">
              <h5><i class="mdi mdi-account-circle me-2"></i>Customer</h5>
            </div>
            <div class="od-card-body">
              <div class="od-customer-info">
                <div class="od-customer-avatar">
                  <i class="mdi mdi-account"></i>
                </div>
                <div>
                  <h6 style="margin: 0; font-weight: 600;"><%= orderList.userId.name %></h6>
                  <p style="margin: 0; color: rgba(255,255,255,0.5); font-size: 0.82rem;"><%= orderList.userId.email %></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Payment Info -->
          <div class="od-card mb-4">
            <div class="od-card-header">
              <h5><i class="mdi mdi-credit-card me-2"></i>Payment</h5>
            </div>
            <div class="od-card-body">
              <div class="od-info-item">
                <span class="od-info-label">Method</span>
                <span class="od-info-value">
                  <i class="mdi mdi-<%= orderList.peyment === 'Cash on Delivery' ? 'cash' : orderList.peyment === 'wallet' ? 'wallet' : 'bank' %> me-1" style="color: #8854d0;"></i>
                  <%= orderList.peyment %>
                </span>
              </div>
              <div class="od-info-item">
                <span class="od-info-label">Status</span>
                <span class="od-info-value">
                  <% if (orderList.orderStatus === 'payment pending') { %>
                    <span style="color: #f6a821;"><i class="mdi mdi-clock-outline me-1"></i>Pending</span>
                  <% } else { %>
                    <span style="color: #00d25b;"><i class="mdi mdi-check-circle me-1"></i>Paid</span>
                  <% } %>
                </span>
              </div>
              <div class="od-info-item">
                <span class="od-info-label">Amount</span>
                <span class="od-info-value" style="font-weight: 700; font-size: 1.05rem;">₹<%= orderList.orderAmount.toFixed(2) %></span>
              </div>
            </div>
          </div>

          <!-- Delivery Address -->
          <div class="od-card mb-4">
            <div class="od-card-header">
              <h5><i class="mdi mdi-map-marker me-2"></i>Delivery Address</h5>
            </div>
            <div class="od-card-body">
              <div class="od-address-block">
                <p class="od-address-name"><i class="mdi mdi-home me-2"></i><%= orderList.deliveryAddress.name %></p>
                <p class="od-address-line"><%= orderList.deliveryAddress.city %>, <%= orderList.deliveryAddress.state %></p>
                <p class="od-address-pin"><i class="mdi mdi-map-marker-radius me-1"></i>PIN: <strong><%= orderList.deliveryAddress.pincode %></strong></p>
              </div>
            </div>
          </div>

        </div>

      </div>

    </div>
  </div>
</div>

<div hidden id="oderId"><%= ordId %></div>

<!-- Order Detail Page Styles -->
<style>
  /* Allow scrolling on this page */
