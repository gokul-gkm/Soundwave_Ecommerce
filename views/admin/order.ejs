  input[type="number"]::-webkit-inner-spin-button,
  input[type="number"]::-webkit-outer-spin-button {
    -webkit-appearance: none !important;
  }
</style>

<script>
  function orderProstatus(e, id, proId) {
    const select = document.getElementById(`s${proId}`);

    // Update select styling
    select.className = 'od-status-select';
    if (e.value === 'canceled') {
      select.classList.add('od-select-canceled');
    } else if (e.value === 'delivered') {
      select.classList.add('od-select-delivered');
    } else {
      select.classList.add('od-select-shipped');
    }

    fetch(`/admin/orders/${id}/items/${proId}`, {
      method: 'PATCH',
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ val: e.value, id, proId })
    }).then(res => res.json()).then(data => {
      if (data.success) {
        // Show brief success indication
        select.style.boxShadow = '0 0 0 2px rgba(0, 210, 91, 0.3)';
        setTimeout(() => { select.style.boxShadow = ''; }, 1500);
      }
    });
  }

  function removeorder(id, pro) {
    const tr = document.getElementById(`c${id}`);
    fetch(`/admin/orders/${id}/items/${pro}`, {
      method: 'DELETE',
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id, pro })
    }).then(res => res.json()).then(data => {
      if (data.succes) {
        tr.remove();
      }
    });
  }

  // Accepting Return
  const orderId = document.getElementById('oderId').textContent.trim();

  function acceptReturn() {
    fetch(`/admin/orders/${orderId}/returns`, { method: 'POST' })
      .then(res => {
        // Reload page to reflect updated status
        window.location.reload();
      });
  }
</script>

