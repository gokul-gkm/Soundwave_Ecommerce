<%- include('../layout/adminlayout.ejs') -%>
  <div class="container-scroller">

    <%- include('../layout/adminnav.ejs') -%>

      <div class="main-panel ">
        <div class="content-wrapper  d-flex flex-column  align-items-center">
          <!-- Edit Product Modal (Glassmorphism) -->
          <link rel="stylesheet" href="/css/admin/productsEditModal.css" />
          <div class="edit-modal-overlay" id="editProductModal">
            <div class="edit-modal-card">
              <form id="myForm1" method="post" enctype="multipart/form-data">
                
                <div class="edit-modal-header">
                  <h3 class="edit-modal-title"><i class="mdi mdi-pencil-circle-outline"></i> Edit Product</h3>
                  <button type="button" class="btn-close-modal" aria-label="Close" onclick="closeEditModal()"><i class="mdi mdi-close"></i></button>
                </div>
                
                <div class="edit-modal-body">
                  <div class="edit-img-grid img-row">
                    <!-- Dynamic images go here -->
                  </div>

                  <div class="edit-form-group">
                    <label class="edit-form-label"><i class="mdi mdi-format-title"></i> Name</label>
                    <input type="text" class="edit-form-control name" name="name" required placeholder="Product Name">
                    <p id="err1" class="text-danger mt-1 mb-0" style="font-size: 12px;"></p>
                  </div>

                  <div class="edit-form-row">
                    <div class="edit-form-group">
                      <label class="edit-form-label"><i class="mdi mdi-currency-usd"></i> Price (₹)</label>
                      <input type="number" class="edit-form-control price" min="0" name="price" required placeholder="0.00">
                    </div>
                    <div class="edit-form-group">
                      <label class="edit-form-label"><i class="mdi mdi-package-variant-closed"></i> Stock</label>
                      <input type="number" class="edit-form-control stock" min="0" name="stock" required placeholder="0">
                    </div>
                  </div>

                  <div class="edit-form-row">
                    <div class="edit-form-group">
                      <label class="edit-form-label"><i class="mdi mdi-tag-outline"></i> Category</label>
                      <select class="edit-form-control category" name="category" required>
                        <% locals.ca.forEach(e=>{ %>
                          <option><%= e.name %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="edit-form-group">
                      <label class="edit-form-label"><i class="mdi mdi-label-multiple-outline"></i> Tags</label>
                      <input type="text" class="edit-form-control tags" name="tags" placeholder="e.g. tech, wireless">
                    </div>
                  </div>

                  <div class="edit-form-group mb-0">
                    <label class="edit-form-label"><i class="mdi mdi-text-box-outline"></i> Description</label>
                    <textarea class="edit-form-control description" name="des" rows="3" required></textarea>
                  </div>
                </div>

                <div class="edit-modal-footer">
                  <button type="button" class="em-btn-cancel" onclick="closeEditModal()">Cancel</button>
                  <button type="submit" class="em-btn-submit"><i class="mdi mdi-check-circle-outline"></i> Update Product</button>
                </div>

              </form>
            </div>
          </div>

          <div class="row hh">
            <div class="circle position-absolute " style="background-color: rebeccapurple;
            filter: blur(136px);
            width: 13rem;
            height: 10rem;
            border-radius: 50%;
            transform: translate(57rem, 23rem);"></div>
            <div class="circle position-absolute " style="background-color: rgba(0, 0, 255, 0.589);
            filter: blur(136px);
            width: 13rem;
            height: 10rem;
            border-radius: 50%;
         "></div>
            <div class="col-12 grid-margin">
              <div class="card " style="height: 80vh; border-radius: 15px; box-shadow: 0 0 0 0; border: 0;">
                <div class="card" style="border-radius: 15px; box-shadow: 0 0 0 0; border: 0;">
                  <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between ">
                      <h4 class="card-title">products</h4>
                      <a href="/admin/products/new" class="btn btn-primary text-white "
                        style="outline: 0; border:0; margin-top: -1rem;">Add product</a>
                    </div>

                    </p>

                    <div class="table-responsive">
                      <table class="table">
                        <thead>
                          <tr>
                            <th> no </th>
                            <th> Name </th>
                            <th> image </th>
                            <th> Stock </th>
                            <th> price </th>
                            <th> Date </th>
                            <th> Cetegory </th>
                            <th> Active </th>
                            <th> options </th>
                          </tr>
                        </thead>
                        <tbody>
                          <% product.forEach((e,i)=>{ %>

                            <tr class="tr" id="e<%=e._id  %>" style="background-color: transparent !important;">
                              <td class="py-1">
                                <%= i+1 %>
                              </td>
                              <td>
                                <%= e.name %>
                              </td>
                              <td>

                                <div class="progress d-flex align-items-center  h-100 w-100  "
                                  style=" background-color: transparent; ">
                                  <%e.images.forEach(im=>{%>
                                    <div class="cir "
                                      style="display: inline-block; width: 30px; height: 30px;  border-radius: 50%; overflow: hidden;">
                                      <img style="width: 100%; height: 100%; object-fit: cover; "
                                        src="<%= im.startsWith('http') ? im : '/productImage/' + im %>" alt="">
                                    </div>

                                    <% }) %>
                                </div>
                              </td>
                              <td>
                                <%=e.stock %>
                              </td>
                              <td>
                                ₹<%=e.price.toFixed(2) %>
                              </td>
                              <td>
                                <%=e.createdAt %>
                              </td>
                              <td>
                                <%=e.category.name %>
                              </td>
                              <td>
                                <div onclick="" style="cursor: pointer;" class="badge  badge-outline-success">
                                  <%=e.status %>
                                </div>
                              </td>
                              <!-- New -->
                              <td>
                                <div onclick="active('<%= e._id %>')" id="b<%=e._id  %>" style="cursor: pointer;"
                                  class="badge  <%= e.listed ? 'badge-outline-success' : 'badge-outline-danger' %>">
                                  <%= e.listed ? 'Listed' : 'Unlisted' %>
                                </div>
                              </td>
                              <!-- New -->

                                <td class=" dropdown"> <a href="#" id="profile-dropdown" data-toggle="dropdown"><i
                                    class="mdi mdi-dots-vertical"></i></a>
                                <div style="min-width: 5rem; padding: .9rem 0; height: max-content; "
                                  class="dropdown-menu dropdown-menu-right navbar-dropdown preview-list   overflow-hidden "
                                  aria-labelledby="profile-dropdown">
                                  <div
                                    class="edit d-flex flex-column gap-2  h-100 w-100 justify-content-center align-items-center ">
                                    <% let b=[]; locals.ca.forEach(e=>{ b.push(e.name) }) %>
                                      <a href="/admin/products/<%=e._id %>" class="fs-5"
                                        style="line-height: 0; margin-bottom: 0; color:#6c7293; text-decoration: none;">
                                        view&nbsp;<i class="ri-eye-line"></i></a>
                                      <br>
                                      <div class="d "
                                        style="width: 100%; height: 1px; background-color: rgba(77, 75, 75, 0.5);">
                                      </div>
                                      <br>
                                      <p onclick="edit('<%=JSON.stringify(e.images)%>','<%= e._id%>','<%= e.name %>','<%=e.stock  %>','<%=e.price  %>','<%=e.category.name  %>','<%= e.description%>','<%= e.tags%>')"
                                        class="fs-5 "
                                        style="cursor: pointer; line-height: 0; margin-bottom: 0; color:#6c7293;">
                                        edit&nbsp;<i class="ri-edit-line  "></i></p>
                                      <br>
                                      <div class="d "
                                        style="width: 100%; height: 1px; background-color: rgba(77, 75, 75, 0.5);">
                                      </div>
                                      <br>
                                      <a href="#"  onclick="deleteProduct('<%= e._id %>')" class="fs-5 "
                                        style="line-height: 0; margin-bottom: 0; color:#6c7293;">
                                        delete&nbsp;<i class="ri-delete-bin-3-line  "></i></a>
                                  </div>


                              </td>
                            </tr>
                            <% }) %>

                        </tbody>
                      </table>

                    </div>

                    <%- include('../layout/pagination.ejs') -%>

                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
  </div>
  </div>


  <script>
    function deleteProduct(proId) {
        // Display a confirmation dialog before proceeding
        if (confirm('Are you sure you want to remove this product?')) {
            // Send an AJAX request to delete the user
            fetch('/admin/products/' + proId, {
                method: 'DELETE',
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Show a success toaster message or any other feedback
                    alert('Product removed successfully');
                    // Reload the page or update the UI as needed
                    location.reload();
                } else {
                    // Show an error toaster message or any other feedback
                    alert('Failed to remove product: ' + data.message);
                }
            })
            .catch(error => console.error('Error removing product:', error));
        }
    }
</script>

<script>
    function active(id) {

    const status = document.getElementById(`status${id}`)
    const btn = document.getElementById(`b${id}`)


    fetch(`/admin/products/${id}/status`, {
      method: 'POST',
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ payload: id})

    }).then(res => res.json()).then(data => {
      console.log("listed:"+data.updatedData.listed)
  
        // status.textContent=data.updatedData.listed

        console.log("listedOrnot: "+data.updatedData);
      
        if(data.updatedData.listed===false){
   
          btn.style.borderColor='#d72624'
          btn.style.color='#d72624'
          btn.textContent="Unlisted"    
        }else{
           
          btn.style.borderColor='#00b032'
          btn.style.color='#00b032'                 
          btn.textContent="Listed"
        }
        
        

    })
    }
  </script>

  <script>
    const imageRow = document.querySelector('.img-row');
    const name1 = document.querySelector('.name');
    const price1 = document.querySelector('.price');
    const stock1 = document.querySelector('.stock');
    const catName1 = document.querySelector('.category');
    const desc1 = document.querySelector('.description');
    const tags1 = document.querySelector('.tags');
    const gg = document.querySelector('.gg');
    const dname = document.querySelector('.dname');
    function removeP(i, im) {
      const wrap = document.getElementById(`imgBoxWrap${i}`);
      const myForm = document.getElementById('myForm1');
      const peFlag = document.createElement('input');
      peFlag.type = 'hidden'; peFlag.name = `pe${i}`; peFlag.value = 'true';
      const peVal = document.createElement('input');
      peVal.type = 'hidden'; peVal.name = `pe`; peVal.value = im;
      myForm.appendChild(peFlag);
      myForm.appendChild(peVal);

      wrap.innerHTML = `
        <label for="image${i}" class="edit-img-circle empty-state">
          <input type="file" class="file" data-index="${i}" id="image${i}" accept="image/jpeg, image/png, image/jpg" name="images${i}" style="display: none;">
          <img id="im${i}" style="display:none;" src="" alt="">
          <div class="empty-icon"><i class="mdi mdi-plus"></i><span>Add</span></div>
          <div class="edit-img-overlay" style="display:none;"><i class="mdi mdi-camera"></i><span>Change</span></div>
        </label>
        <button type="button" style="display:none;" class="remove-btn-circular" id="removeBtn${i}" onclick="removeNewlyAddedP('${i}')" title="Remove"><i class="mdi mdi-close"></i></button>
      `;
      document.getElementById(`image${i}`).addEventListener('change', () => fileeObj(i));
    }

    function removeNewlyAddedP(i) {
      const wrap = document.getElementById(`imgBoxWrap${i}`);
      const fileInput = document.getElementById(`image${i}`);
      if(fileInput) fileInput.value = '';
      wrap.innerHTML = `
        <label for="image${i}" class="edit-img-circle empty-state">
          <input type="file" class="file" data-index="${i}" id="image${i}" accept="image/jpeg, image/png, image/jpg" name="images${i}" style="display: none;">
          <img id="im${i}" style="display:none;" src="" alt="">
          <div class="empty-icon"><i class="mdi mdi-plus"></i><span>Add</span></div>
          <div class="edit-img-overlay" style="display:none;"><i class="mdi mdi-camera"></i><span>Change</span></div>
        </label>
        <button type="button" style="display:none;" class="remove-btn-circular" id="removeBtn${i}" onclick="removeNewlyAddedP('${i}')" title="Remove"><i class="mdi mdi-close"></i></button>
      `;
      document.getElementById(`image${i}`).addEventListener('change', () => fileeObj(i));
    }

    function edit(image, id, name, stock, price, catName, desc, tags) {
      const myForm = document.getElementById('myForm1');
      const editModal = document.getElementById('editProductModal');
      myForm.action = `/admin/products/${id}`;
      
      const imgs = JSON.parse(image);
      document.querySelector('.name').value = name;
      document.querySelector('.price').value = price;
      document.querySelector('.stock').value = stock;
      document.querySelector('.category').value = catName;
      document.querySelector('.description').value = desc;      
      document.querySelector('.tags').value = tags; 
    
      let html = '';
      for(let i=0; i<3; i++) {
        let im = imgs[i];
        if(im && im !== null && im !== '') {
           let imgSrc = im.startsWith('http') ? im : '/productImage/' + im;
           html += `
            <div id="imgBoxWrap${i}" class="edit-img-wrap">
              <label for="image${i}" class="edit-img-circle">
                <input type="file" class="file" data-index="${i}" id="image${i}" accept="image/jpeg, image/png, image/jpg" name="images${i}" style="display: none;" value="${im}">
                <img id="im${i}" src="${imgSrc}" alt="">
                <div class="edit-img-overlay">
                  <i class="mdi mdi-camera"></i>
                  <span>Change</span>
                </div>
              </label>
              <button type="button" class="remove-btn-circular" onclick="removeP('${i}', '${im}')" title="Remove"><i class="mdi mdi-close"></i></button>
            </div>`;
        } else {
           html += `
            <div id="imgBoxWrap${i}" class="edit-img-wrap">
              <label for="image${i}" class="edit-img-circle empty-state">
                <input type="file" class="file" data-index="${i}" id="image${i}" accept="image/jpeg, image/png, image/jpg" name="images${i}" style="display: none;">
                <img id="im${i}" style="display:none;" src="" alt="">
                <div class="empty-icon"><i class="mdi mdi-plus"></i><span>Add</span></div>
                <div class="edit-img-overlay" style="display:none;">
                  <i class="mdi mdi-camera"></i>
                  <span>Change</span>
                </div>
              </label>
              <button type="button" style="display:none;" class="remove-btn-circular" id="removeBtn${i}" onclick="removeNewlyAddedP('${i}')" title="Remove"><i class="mdi mdi-close"></i></button>
            </div>`;
        }
      }
      document.querySelector('.img-row').innerHTML = html;
      editModal.classList.add('active');

      for (let i = 0; i < 3; i++) {
        const fileInput = document.getElementById(`image${i}`);
        if(fileInput) { fileInput.addEventListener('change', () => fileeObj(i)); }
      }
    }

    function fileeObj(i) {
      let file = document.getElementById(`image${i}`);
      let img = document.getElementById(`im${i}`);
      let label = file.closest('label');
      let emptyIcon = label.querySelector('.empty-icon');
      let overlay = label.querySelector('.edit-img-overlay');
      let removeBtn = document.getElementById(`removeBtn${i}`);
      
      let uploadedFile = file.files ? file.files[0] : null;
      if (uploadedFile) {
        if (['image/png', 'image/jpeg', 'image/jpg', 'image/webp'].includes(uploadedFile.type)) {
          img.src = URL.createObjectURL(uploadedFile);
          img.style.display = 'block';
          label.classList.remove('empty-state');
          if(emptyIcon) emptyIcon.style.display = 'none';
          if(overlay) overlay.style.display = 'flex';
          if(removeBtn) removeBtn.style.display = 'flex';
        } else {
          alert("Please upload only PNG, JPEG, JPG, or WEBP files.");
          file.value = '';
        }
      }
    }

    function closeEditModal() {
      document.getElementById('editProductModal').classList.remove('active');
    }

  </script>
