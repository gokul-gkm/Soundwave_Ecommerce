<%- include('../layout/adminlayout.ejs') -%>
<link rel="stylesheet" href="/css/admin/coupons.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

<div class="container-scroller">
  <%- include('../layout/adminnav.ejs') -%>

  <div class="main-panel">
    <div class="content-wrapper" style="padding: 1.5rem 2rem;">

      <!-- Decorative Background Blurs -->
      <div class="circle position-fixed" style="background-color: rebeccapurple; filter: blur(136px); width: 13rem; height: 10rem; border-radius: 50%; right: 5rem; top: 20rem; z-index: 0; pointer-events: none;"></div>
      <div class="circle position-fixed" style="background-color: rgba(0, 0, 255, 0.589); filter: blur(136px); width: 13rem; height: 10rem; border-radius: 50%; left: 15rem; top: 5rem; z-index: 0; pointer-events: none;"></div>

      <!-- Page Header -->
      <div class="cp-page-header" style="position: relative; z-index: 1;">
        <div>
          <h3 class="cp-page-title">Coupons</h3>
          <p class="cp-page-subtitle">Manage discount coupons for your store · <%= coupon.length %> coupon<%= coupon.length !== 1 ? 's' : '' %></p>
        </div>
        <button class="cp-add-btn" onclick="openAddModal()">
          <i class="mdi mdi-plus-circle-outline"></i> Add Coupon
        </button>
      </div>

      <!-- Coupons Grid -->
      <div style="position: relative; z-index: 1;">
        <% if (coupon.length === 0) { %>
        <div class="cp-card">
          <div class="cp-card-body">
            <div class="cp-empty-state">
              <i class="mdi mdi-ticket-outline"></i>
              <p>No coupons yet. Click "Add Coupon" to create your first one.</p>
            </div>
          </div>
        </div>
        <% } else { %>
        <div class="row">
          <% coupon.forEach((e, j) => { %>
          <div class="col-xl-4 col-md-6 mb-4" id="cpCard<%= e._id %>">
            <div class="cp-card cp-coupon-card">
              <div class="cp-card-body">
                <div class="cp-offer-badge"><%= e.offer %>% OFF</div>

                <% if (e.image) { %>
                <img class="cp-coupon-image" src="<%= e.image.startsWith('http') ? e.image : '/productImage/' + e.image %>" alt="<%= e.name %>" />
                <% } else { %>
                <div class="cp-coupon-no-image"><i class="mdi mdi-ticket-percent"></i></div>
                <% } %>

                <h6 class="cp-coupon-name"><%= e.name %></h6>
                <span class="cp-coupon-id"><%= e.ID %></span>

                <div class="cp-coupon-stats">
                  <div class="cp-coupon-stat">
                    <span class="cp-coupon-stat-label">Min</span>
                    <span class="cp-coupon-stat-value">₹<%= e.from %></span>
                  </div>
                  <div class="cp-coupon-stat">
                    <span class="cp-coupon-stat-label">Max</span>
                    <span class="cp-coupon-stat-value">₹<%= e.to %></span>
                  </div>
                  <div class="cp-coupon-stat cp-coupon-stat-offer">
                    <span class="cp-coupon-stat-label">Discount</span>
                    <span class="cp-coupon-stat-value"><%= e.offer %>%</span>
                  </div>
                </div>

                <div class="cp-coupon-actions">
                  <button class="cp-action-btn cp-btn-edit" onclick="openEditModal('<%= e._id %>', '<%= e.name %>', '<%= e.from %>', '<%= e.to %>', '<%= e.offer %>', '<%= e.image %>')">
                    <i class="mdi mdi-pencil-outline"></i> Edit
                  </button>
                  <button class="cp-action-btn cp-btn-delete" onclick="openDeleteModal('<%= e._id %>', '<%= e.name %>')">
                    <i class="mdi mdi-delete-outline"></i> Delete
                  </button>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<!-- Add/Edit Coupon Modal -->
<div class="modal fade" id="couponModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width: 480px;">
    <div class="modal-content cp-modal">
      <div class="modal-header cp-modal-header">
        <h5 class="modal-title cp-modal-title" id="couponModalTitle">
          <i class="mdi mdi-ticket-percent me-2"></i>Add Coupon
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="couponForm" action="/admin/coupons" method="post" enctype="multipart/form-data">
        <div class="modal-body cp-modal-body">

          <!-- Image Upload -->
          <div class="cp-form-group">
            <label class="cp-form-label">Coupon Image</label>
            <label for="cpImageInput" class="cp-img-upload" id="cpImgUploadArea">
              <input type="file" accept="image/*" name="images" id="cpImageInput" />
              <div class="cp-img-placeholder" id="cpImgPlaceholder">
                <i class="mdi mdi-cloud-upload-outline"></i>
                <span>Click to upload image</span>
              </div>
              <img src="" alt="" class="cp-img-preview" id="cpImgPreview" />
              <div class="cp-img-overlay" id="cpImgOverlay"><i class="mdi mdi-camera me-2"></i>Replace</div>
            </label>
          </div>

          <!-- Name -->
          <div class="cp-form-group">
            <label class="cp-form-label">Coupon Name</label>
            <input type="text" class="cp-form-input" name="name" id="cpName" placeholder="e.g. Summer Sale" required />
          </div>

          <!-- Price Range -->
          <div class="cp-form-row">
            <div class="cp-form-group">
              <label class="cp-form-label">Min Price (₹)</label>
              <div class="cp-input-group">
                <span class="cp-input-prefix">₹</span>
                <input type="number" class="cp-form-input" name="from" id="cpFrom" min="0" placeholder="500" required />
              </div>
            </div>
            <div class="cp-form-group">
              <label class="cp-form-label">Max Price (₹)</label>
              <div class="cp-input-group">
                <span class="cp-input-prefix">₹</span>
                <input type="number" class="cp-form-input" name="to" id="cpTo" min="0" placeholder="5000" required />
              </div>
            </div>
          </div>

          <!-- Offer -->
          <div class="cp-form-group mb-0">
            <label class="cp-form-label">Discount Percentage</label>
            <div class="cp-input-group">
              <input type="number" class="cp-form-input" name="offer" id="cpOffer" min="1" max="100" placeholder="10" required />
              <span class="cp-input-suffix">%</span>
            </div>
          </div>

        </div>
        <div class="modal-footer cp-modal-footer">
          <button type="button" class="cp-cancel-btn" style="width: auto;" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="cp-submit-btn" style="width: auto; margin-top: 0;" id="cpSubmitBtn">
            <i class="mdi mdi-check-circle-outline"></i> <span id="cpSubmitText">Create Coupon</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
    <div class="modal-content cp-modal cp-delete-modal">
      <div class="modal-body cp-modal-body text-center p-4">
        <div class="cp-delete-glow"></div>
        <div class="cp-delete-icon-wrapper">
          <i class="mdi mdi-delete-alert"></i>
        </div>
        <h4 class="cp-delete-heading">Delete Coupon?</h4>
        <p class="cp-delete-text mt-3">You are about to permanently delete the coupon</p>
        <div class="cp-delete-target-box">
          <i class="mdi mdi-ticket-percent"></i> <span id="deleteCouponName">"Coupon"</span>
        </div>
        <p class="cp-delete-warning">This action cannot be undone.</p>
        
        <div class="d-flex justify-content-center gap-3 mt-4">
          <button type="button" class="cp-cancel-btn m-0" style="flex: 1;" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="cp-delete-confirm-btn m-0" style="flex: 1;" id="confirmDeleteBtn" onclick="confirmDelete()">
            Yes, Delete
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Scripts -->
<script>
  const couponModal = new bootstrap.Modal(document.getElementById('couponModal'));
  const deleteModalEl = new bootstrap.Modal(document.getElementById('deleteModal'));
  const couponForm = document.getElementById('couponForm');
  const cpImageInput = document.getElementById('cpImageInput');
  const cpImgPreview = document.getElementById('cpImgPreview');
  const cpImgPlaceholder = document.getElementById('cpImgPlaceholder');

  let deleteTargetId = null;

  // Open Add Modal
  function openAddModal() {
    resetForm();
    document.getElementById('couponModalTitle').innerHTML = '<i class="mdi mdi-ticket-percent me-2"></i>Add Coupon';
    document.getElementById('cpSubmitText').textContent = 'Create Coupon';
    couponForm.action = '/admin/coupons';
    cpImageInput.required = true;
    couponModal.show();
  }

  // Open Edit Modal
  function openEditModal(id, name, from, to, offer, image) {
    resetForm();
    document.getElementById('couponModalTitle').innerHTML = '<i class="mdi mdi-pencil me-2"></i>Edit Coupon';
    document.getElementById('cpSubmitText').textContent = 'Update Coupon';
    couponForm.action = `/admin/coupons/${id}`;
    cpImageInput.required = false;

    document.getElementById('cpName').value = name;
    document.getElementById('cpFrom').value = from;
    document.getElementById('cpTo').value = to;
    document.getElementById('cpOffer').value = offer;

    if (image) {
      const imgSrc = image.startsWith('http') ? image : '/productImage/' + image;
      cpImgPreview.src = imgSrc;
      cpImgPreview.style.display = 'block';
      cpImgPlaceholder.style.display = 'none';
    }

    couponModal.show();
  }

  // Reset form
  function resetForm() {
    couponForm.reset();
    cpImgPreview.style.display = 'none';
    cpImgPlaceholder.style.display = 'flex';
  }

  // Image preview
  cpImageInput.addEventListener('change', function () {
    if (this.files && this.files[0]) {
      const validTypes = ['image/png', 'image/jpeg', 'image/jpg', 'image/webp'];
      if (!validTypes.includes(this.files[0].type)) {
        alert('Please upload only PNG, JPEG, JPG or WebP files.');
        this.value = null;
        return;
      }
      cpImgPreview.src = URL.createObjectURL(this.files[0]);
      cpImgPreview.style.display = 'block';
      cpImgPlaceholder.style.display = 'none';
    }
  });

  // Open Delete Modal
  function openDeleteModal(id, name) {
    deleteTargetId = id;
    document.getElementById('deleteCouponName').textContent = `"${name}"`;
    deleteModalEl.show();
  }

  // Confirm Delete
  function confirmDelete() {
    if (!deleteTargetId) return;

    fetch(`/admin/coupons/${deleteTargetId}`, { method: 'DELETE' })
      .then(res => res.json())
      .then(data => {
        if (data.set) {
          const card = document.getElementById(`cpCard${deleteTargetId}`);
          if (card) {
            card.style.transition = 'all 0.35s ease';
            card.style.opacity = '0';
            card.style.transform = 'scale(0.9)';
            setTimeout(() => card.remove(), 350);
          }
          deleteModalEl.hide();
          deleteTargetId = null;
        }
      });
  }
</script>

<script src="/vendors/js/vendor.bundle.base.js"></script>
<script src="/vendors/chart.js/Chart.min.js"></script>
<script src="/vendors/progressbar.js/progressbar.min.js"></script>
<script src="/vendors/jvectormap/jquery-jvectormap.min.js"></script>
<script src="/vendors/jvectormap/jquery-jvectormap-world-mill-en.js"></script>
<script src="/js/off-canvas.js"></script>
<script src="/js/hoverable-collapse.js"></script>
<script src="/js/misc.js"></script>
<script src="/js/settings.js"></script>
<script src="/js/todolist.js"></script>
<script src="/js/dashboard.js"></script>
<script src="/js/base.js"></script>

</body>
</html>