<%- include('../layout/header.ejs') -%>
<link rel="stylesheet" href="css/mycss/profile.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>
<body>
  <%- include('../layout/nave.ejs') -%>
  <nav aria-label="breadcrumb" class="breadcrumb-nav mb-3">
    <div class="container">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">My Account</li>
      </ol>
    </div>
    <!-- End .container -->
  </nav>
  <br />

  <section class="main-content-section">
    <div class="container-fluid py-5 h-100 position-relative">
      <div class="row d-flex align-items-start h-100 gy-4">
        <aside class="col-lg-3 col-md-4 col-12">
          <%- include('../layout/profileSidebar', { activePage: 'profile' }) %>
        </aside>
        
        <div class="col-lg-9 col-md-8 col-12 mb-4 mb-lg-0">
          <div class="amz-card profile-card">
            <!-- Profile Header/Dashboard -->
            <div class="profile-header">
              <div class="d-flex align-items-center gap-4 flex-wrap">
                <div class="avatar-wrapper">
                  <img src="/images/profile/profile.png" alt="Avatar" class="avatar-img" />
                </div>
                <div class="user-meta">
                  <h2 class="user-name"><%= user.name %></h2>
                  <p class="user-email text-muted mb-0"><%= user.email %></p>
                  <div class="wallet-badge mt-2">
                    <i class="fas fa-wallet me-2"></i> Wallet: <strong>₹<%= locals.walletAmount %></strong>
                    <% if(locals.wallet1) { %>
                      <a href="/wallet" class="ms-2 history-link">View History <i class="ri-arrow-right-line"></i></a>
                    <% } %>
                  </div>
                </div>
              </div>
              
              <form action="/logout" method="post" id="logoutForm2" class="ms-auto pb-3 pb-md-0">
                <button type="button" class="signout-btn" id="logoutButton2" title="Sign Out">
                  <i class="ri-logout-circle-line me-2"></i> Sign Out
                </button>
              </form>
            </div>

            <!-- Profile Details Content -->
            <div class="card-body p-4 p-md-5">
              <div class="row">
                <!-- Personal Info Column -->
                <div class="col-lg-6">
                  <div class="section-title-wrapper mb-4">
                    <h5 class="section-title"><i class="fas fa-user-circle me-2 text-primary"></i> Personal Information</h5>
                    <div class="section-line"></div>
                  </div>
                  
                  <div class="info-group mb-4">
                    <label class="info-label">Full Name</label>
                    <p class="info-value"><%= user.name %></p>
                  </div>
                  
                  <div class="info-group mb-4">
                    <label class="info-label">Phone Number</label>
                    <p class="info-value"><%= user.phone %></p>
                  </div>

                  <div class="info-group mb-4">
                    <label class="info-label">Email Address</label>
                    <p class="info-value"><%= user.email %></p>
                  </div>
                </div>

                <!-- Security / Actions Column -->
                <div class="col-lg-6">
                  <div class="section-title-wrapper mb-4">
                    <h5 class="section-title"><i class="fas fa-shield-alt me-2 text-primary"></i> Security & Settings</h5>
                    <div class="section-line"></div>
                  </div>

                  <p class="text-muted small mb-4">Manage your account security and profile details here. Ensure your contact information is up to date.</p>

                  <div class="d-grid gap-3">
                    <button type="button" class="amz-btn amz-btn-primary w-100" data-bs-toggle="modal" data-bs-target="#exampleModal">
                      <i class="far fa-edit me-2"></i> Edit Account Profile
                    </button>
                    <button type="button" class="amz-btn amz-btn-secondary w-100" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                      <i class="fas fa-lock me-2"></i> Update Password
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  
  <!-- Edit Profile Modal -->
  <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal">
            <div class="modal-header border-0">
                <h5 class="modal-title font-weight-bold" id="exampleModalLabel">Edit Account Profile</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 pb-4 m-4">
                <form action="/profile?userId=<%= user._id %>" method="post" id="editProfileForm" enctype="application/x-www-form-urlencoded">
                    <div class="mb-4">
                        <label for="userName" class="form-label font-weight-semibold">Full Name</label>
                        <input type="text" class="form-control custom-input" name="name" id="userName" value="<%= user.name %>" placeholder="Enter your full name">
                        <div class="error text-danger small mt-1" id="nameError"></div>
                    </div>
                    <div class="mb-4">
                        <label for="userPhone" class="form-label font-weight-semibold">Contact Number</label>
                        <input type="text" class="form-control custom-input" name="phone" id="userPhone" value="<%= user.phone %>" placeholder="Enter 10-digit number">
                        <div class="error text-danger small mt-1" id="phoneError"></div>
                    </div>
                    <div class="d-flex gap-2 mt-2">
                        <button type="button" class="amz-btn amz-btn-secondary flex-grow-1" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" id="saveButton" class="amz-btn amz-btn-primary flex-grow-1" onclick="submitEditProfileForm('<%= user._id %>')">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
  </div>

  <!-- Change Password Modal -->
  <div class="modal fade" id="changePasswordModal" tabindex="-1" aria-labelledby="changePasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
       <div class="modal-content custom-modal">
         <div class="modal-header border-0">
           <h5 class="modal-title font-weight-bold" id="changePasswordModalLabel">Security: Change Password</h5>
           <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
         </div>
         <div class="modal-body px-4 pb-4 m-4">
           <form action="/changePassword" method="post" id="changePasswordForm">
             <div class="mb-3">
               <label for="currentPassword" class="form-label font-weight-semibold">Current Password</label>
               <input type="password" class="form-control custom-input" name="currentPassword" id="currentPassword" placeholder="••••••••" required>
             </div>
             <div class="mb-3">
               <label for="newPassword" class="form-label font-weight-semibold">New Password</label>
               <input type="password" class="form-control custom-input" name="newPassword" id="newPassword" placeholder="••••••••" required>
             </div>
             <div class="mb-4">
               <label for="confirmPassword" class="form-label font-weight-semibold">Confirm New Password</label>
               <input type="password" class="form-control custom-input" name="confirmPassword" id="confirmPassword" placeholder="••••••••" required>
             </div>
             <div class="d-flex gap-2 mt-2">
               <button type="button" class="amz-btn amz-btn-secondary flex-grow-1" data-bs-dismiss="modal">Cancel</button>
               <button type="submit" class="amz-btn amz-btn-primary flex-grow-1">Update Password</button>
             </div>
           </form>
         </div>
       </div>
    </div>
   </div>
 




