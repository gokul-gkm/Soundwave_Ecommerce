<script>
// Sidebar logout (from reusable partial)
const sidebarLogoutForm = document.getElementById('sidebarLogoutForm');
if (sidebarLogoutForm) {
  sidebarLogoutForm.addEventListener('submit', function(event) {
    event.preventDefault();
    showLogoutConfirmation(event, 'sidebarLogoutForm');
  });
}

// Profile card logout
document.getElementById('logoutButton2').addEventListener('click', function(event) {
 event.preventDefault();
 showLogoutConfirmation(event, 'logoutForm2');
});

function showLogoutConfirmation(event, formId) {
 Swal.fire({
    title: 'Do you really want to logout?',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#3085d6',
    cancelButtonColor: '#d33',
    confirmButtonText: 'Yes, logout'
 }).then((result) => {
    if (result.isConfirmed) {
      document.getElementById(formId).submit();
    }
 });
}

</script>

