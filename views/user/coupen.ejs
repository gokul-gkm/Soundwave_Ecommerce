            <section class="">
        <div class="container-fluid py-5 h-100 position-relative">
            <div class="row d-flex align-items-start h-100 gy-4">
                <aside class="col-lg-3 col-md-4 col-12">
                    <%- include('../layout/profileSidebar', { activePage: 'coupon' }) %>
                </aside>
                
                <aside class="col-lg-9 col-md-8 col-12 mb-4 mb-lg-0">
                    <div class="w-100">
                        <div class="row g-4 m-0">
                            <% if (locals.coupen && coupen.length > 0) { %>
                                <% coupen.forEach((e,i)=>{ %>
                                <div class="col-xl-6 col-lg-12 col-md-12 col-12 mt-1">
                                                <div class="amz-ticket">
                                                    <!-- Left Side: Image & details -->
                                                    <div class="ticket-left">
                                                        <div class="ticket-img-wrapper">
                                                            <img src="<%= e.coupenId.image.startsWith('http') ? e.coupenId.image : '/productImage/' + e.coupenId.image %>" alt="Coupon">
                                                        </div>
                                                        <div class="ticket-info">
                                                            <h4 class="offer-title"><%= e.coupenId.offer %>% OFF</h4>
                                                            <p class="offer-desc"><%= e.coupenId.name %></p>
                                                        </div>
                                                    </div>
                                                    
                                                    <!-- Right Side: Scratch Code -->
                                                    <div class="ticket-right">
                                                        <div class="scratch-container" id="scratch-container-<%= i %>">
                                                            <div class="code-revealed" id="code-<%= i %>"><%= e.ID %></div>
                                                            <canvas class="scratch-canvas" id="canvas-<%= i %>" width="160" height="60"></canvas>
                                                        </div>
                                                        <p class="text-muted small mt-2 text-center" style="font-size: 0.75rem;">Scratch to reveal & copy</p>
                                                    </div>
                                                </div>
                                            </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-12 text-center py-5">
                                <i class="fas fa-ticket-alt fa-3x text-muted mb-3"></i>
                                <h4 class="text-muted">No coupons available right now.</h4>
                            </div>
                        <% } %>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </section>

            <script>
                document.addEventListener("DOMContentLoaded", function() {
                    const canvases = document.querySelectorAll('.scratch-canvas');
                    canvases.forEach((canvas, index) => {
                        const ctx = canvas.getContext('2d');
                        const codeElement = document.getElementById('code-' + index);
                        const codeText = codeElement.textContent.trim();
                        let isDrawing = false;
                        let isScratched = false;

                        // Fill gold overlay
                        ctx.fillStyle = '#c96';
                        ctx.fillRect(0, 0, canvas.width, canvas.height);
                        
                        // Add subtle pattern/text
                        ctx.font = "bold 14px Arial";
                        ctx.fillStyle = "#ffffff";
                        ctx.textAlign = "center";
                        ctx.textBaseline = "middle";
                        ctx.fillText("SCRATCH ME", canvas.width / 2, canvas.height / 2);

                        function getPosition(e) {
                            const rect = canvas.getBoundingClientRect();
                            const scaleX = canvas.width / rect.width;
                            const scaleY = canvas.height / rect.height;
                            
                            let clientX = e.clientX;
                            let clientY = e.clientY;
                            
                            if(e.touches && e.touches.length > 0) {
                                clientX = e.touches[0].clientX;
                                clientY = e.touches[0].clientY;
                            }
                            
                            return {
                                x: (clientX - rect.left) * scaleX,
                                y: (clientY - rect.top) * scaleY
                            };
                        }

                        function scratch(x, y) {
                            ctx.globalCompositeOperation = 'destination-out';
                            ctx.beginPath();
                            ctx.arc(x, y, 15, 0, Math.PI * 2);
                            ctx.fill();
                        }

                        function startInteraction(e) {
                            isDrawing = true;
                            const pos = getPosition(e);
                            scratch(pos.x, pos.y);
                        }

                        function moveInteraction(e) {
                            if (!isDrawing) return;
                            const pos = getPosition(e);
                            scratch(pos.x, pos.y);
                            checkScratchedPercent();
                        }

                        function endInteraction(e) {
                            isDrawing = false;
                        }

                        canvas.addEventListener('mousedown', startInteraction);
                        canvas.addEventListener('mousemove', moveInteraction);
                        canvas.addEventListener('mouseup', endInteraction);
                        canvas.addEventListener('mouseleave', endInteraction);
                        
                        // Optional touch support (Passive false to prevent scroll not standard here, so check bounds)
                        canvas.addEventListener('touchstart', startInteraction, {passive: true});
                        canvas.addEventListener('touchmove', moveInteraction, {passive: true});
                        canvas.addEventListener('touchend', endInteraction);

                        function checkScratchedPercent() {
                            if(isScratched) return;
                            const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                            const pixels = imageData.data;
                            let transparentPixels = 0;
                            
                            for (let i = 3; i < pixels.length; i += 4) {
                                if (pixels[i] === 0) transparentPixels++;
                            }
                            
                            const totalPixels = pixels.length / 4;
                            const clearedPercentage = (transparentPixels / totalPixels) * 100;
                            
                            if (clearedPercentage > 45) {
                                isScratched = true;
                                ctx.clearRect(0, 0, canvas.width, canvas.height);
                                canvas.style.display = 'none'; // hide canvas completely
                                copyToClipboard(codeText);
                            }
                        }
                    });

                    function copyToClipboard(text) {
                        if(navigator.clipboard && window.isSecureContext) {
                            navigator.clipboard.writeText(text).then(() => {
                                fireSwal(text);
                            });
                        } else {
                            const temp = document.createElement("input");
                            temp.value = text;
                            document.body.appendChild(temp);
                            temp.select();
                            document.execCommand("copy");
                            document.body.removeChild(temp);
                            fireSwal(text);
                        }
                    }

                    function fireSwal(text) {
                        Swal.fire({
                            title: "Code Revealed!",
                            text: "Coupon code copied: " + text,
                            icon: "success",
                            confirmButtonColor: "#c96",
                            timer: 3000
                        });
                    }
                });
            </script>

            <%- include('../layout/mobMenu.ejs') -%>
