<%- include('../layout/header.ejs') -%>
<link rel="stylesheet" href="/css/mycss/profile.css" />
</head>
<body>
  <%- include('../layout/nave.ejs') -%>
  <nav aria-label="breadcrumb" class="breadcrumb-nav mb-0">
    <div class="container">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="index.html">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">My Account</li>
      </ol>
    </div>
    <!-- End .container -->
  </nav>
  <br />

  <section class="">
    <div class="container-fluid py-5 h-100 position-relative">
      <div class="row d-flex align-items-start h-100" style="gap: 10rem">
        
        <%- include('../layout/profileSidebar', { activePage: 'orders' }) %>
        
        <aside class="col-lg-9 col-md-8 col-12 mb-4 mb-lg-0">
          <div class="row w-100" style="gap: 2rem">
            <div class="container-fluid">
              <% if(locals.ordercount > 0) { %> 
              <div class="table-responsive">
                <table class="table table-wishlist table-mobile">
                <thead>
                  <tr>
                    <th>No</th>
                    <th>Order ID</th>
                    <th>order Status</th>
                    <th>Items</th>
                    <th>Coupen offer</th>
                    <th>Total price</th>
                    <th>Detailes</th>
                  </tr>
                </thead>

                <tbody>
                  <% if(locals.order) {%> <% order.forEach((e, index)=>{ %>
                  <tr>
                    <td><%= (currentPage - 1) * limit + index + 1 %></td>
                    <td class="">
                      <%= e._id %>

                      <!-- End .product -->
                    </td>
                    <td
                      class="price-col <%= e.orderStatus == 'delivered' ? 'text-success' : e.orderStatus == 'canceled' ? 'text-danger' : 'text-primary' %>
                      "
                    >
                      <%=e.orderStatus %>
                    </td>
                    <td class=""><%=e.OrderedItems.length %></td>

                    <td class="text-center"><%if(e.coupen){%><%=e.coupen %>% <%} else {%>No coupen used<%}%></td>
                    
                    <td class="price-col">₹<%=e.orderAmount %></td>
                    <td>
                      <a
                        href="/orders/<%=e._id  %>"
                        style="
                          border-radius: 5px;
                          border: 0px solid transparent;
                          outline: 0px;
                          transition: all ease 0.5s;
                          background-color: #c96;
                        "
                        class="p-3 rounded-2 text-white"
                        >Details</a
                      >
                    </td>
                  </tr>
                  <% })} %>
                </tbody>
              </table>
              </div>
              <!-- Pagination -->
              <% if (totalPages > 1) { %>
              <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                  <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="?page=<%= currentPage - 1 %>" aria-label="Previous">
                      <span aria-hidden="true">&laquo; Previous</span>
                    </a>
                  </li>
                  
                  <% for(let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                      <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                    </li>
                  <% } %>

                  <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="?page=<%= currentPage + 1 %>" aria-label="Next">
                      <span aria-hidden="true">Next &raquo;</span>
                    </a>
                  </li>
                </ul>
              </nav>
              <% } %>

              <div class="wishlist-share mt-3">
                <div class="social-icons social-icons-sm mb-2">
                  <label class="social-label">Total Orders Found:</label>
                  <span class="text-primary font-weight-bold"><%= ordercount %></span>
                </div>
              </div>

              <% } else { %>
                <div class="text-center py-5">
                  <i class="fas fa-shopping-basket fa-3x text-muted mb-3"></i>
                  <h2 class="text-muted">No orders found yet!</h2>
                  <a href="/category" class="btn btn-primary mt-3" style="background-color: #c96; border: none;">Start Shopping</a>
                </div>
              <% } %>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- <div class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true" style="background-color: blue;">
    <div class="d-flex">
      <div class="toast-body">
        Payment failed! Please try again.
      </div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
  </div> -->

  <%- include('../layout/mobMenu.ejs') -%> <%- include('../layout/lyfooter') -%>


  
  <style>
    *::-webkit-scrollbar {
      width: 0;
    }

    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
      -webkit-appearance: none !important;
    }

    /* Pagination Styling */
    .pagination .page-link {
      color: #333;
      border: 1px solid #ebebeb;
      margin: 0 3px;
      border-radius: 4px !important;
      padding: 8px 16px;
    }
    .pagination .page-item.active .page-link {
      background-color: #c96;
      border-color: #c96;
      color: #fff;
    }
    .pagination .page-item.disabled .page-link {
      color: #ccc;
      pointer-events: none;
    }
    .pagination .page-link:hover {
      background-color: #f4f4f4;
      border-color: #c96;
      color: #c96;
    }
    .table-wishlist td {
      vertical-align: middle;
      padding-top: 1.5rem;
      padding-bottom: 1.5rem;
    }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/locomotive-scroll@3.5.4/dist/locomotive-scroll.js"></script>
  <script src="js/demos/demo-6.js"></script>
  <script src="https://unpkg.com/@studio-freight/lenis@1.0.33/dist/lenis.min.js"></script>
  <%- include('../layout/footer.ejs') -%>
  <!-- <script src="js/base.js"></script> -->
</body>
