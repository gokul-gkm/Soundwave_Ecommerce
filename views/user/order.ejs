<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
  function failedPaymentRetry( ordId , amount){
    console.log(ordId , amount);

    fetch('/payments/retry',{
        method:"POST",
        headers:{'Content-type':'application/json'},
        body: JSON.stringify({ amount })
    }).then(res=> res.json()).then(data=>{
        if (data.succes) {
                    console.log(data)
                    let options = {
                                    "key": `${data.key_id}`,
                                    "amount": `${data.amount}`,
                                    "currency": "INR",
                                    "name": "soundwave",
                                    "order_id": `${data.order_id}`,
                                    "handler": function (response) {
                                        // Call the second fetch on successful payment
                                        fetch('/payments/retry-status', {
                                            method: 'POST',
                                            headers: { 'Content-type': 'application/json' },
                                            body: JSON.stringify({ ordId })
                                        })
                                        .then(res => res.json())
                                        .then(data => {
                                            if (data.success) {
                                                location.reload();
                                            }
                                        });
                                    },
                                    "profile": {
                                        "name": `${data.name}`,
                                        "email": `${data.email}`
                                    }
                                }
								let razorpayObject = new Razorpay(options);
                  
                    razorpayObject.on('payment.failed', (response) => {
                        location.reload();
                    });
                    razorpayObject.open();
    }})

}

</script>

<script>
  const submit= document.getElementById('submitReview')
   function check(e){
       if(e.value.trim()==''){
           submit.style.pointerEvents='none';
           submit.style.opacity=.6;
       }else{
           submit.style.pointerEvents='all';
           submit.style.opacity=1;
           
       }
   }
 </script>

<script>
  // Get the modal
  var modal = document.getElementById("myModal");
  
  // Function to open the modal
  function openModal(productId) {
    document.getElementById('reviewForm').action = "/reviews/" + productId;
    modal.style.display = "block";
  }
  
  // Function to close the modal
  function closeModal() {
    modal.style.display = "none";
  }
  
  // Close the modal when clicking outside of it
  window.onclick = function(event) {
    if (event.target == modal) {
      modal.style.display = "none";
    }
  }
</script>  

<!-- cancel order script -->

<script>
  async function cancel(id,orderId, user, price) {
    const status = document.getElementById(`st${id}`);
    const btn = document.getElementById(`bt${id}`);
    
  const {value: cancelReason} = await Swal.fire({
    title: "Cancel reason",
    input: "text",
    inputLabel: "Cancel reason",
    showCancelButton: true,
    inputValidator: (value)=>{
      if(!value){
        return "You need to write something"
      }
    }
  });
  if(cancelReason){
        edit(id,orderId,user,price,cancelReason);
        Swal.price({
          title:"succes",
          text: "Canceled order is success check your wallet",
          icon: "success"
        })
      }
  }

  function edit(id,orderId, user, price,cancelReason) {
    const status = document.getElementById(`st${id}`);
    const btn = document.getElementById(`bt${id}`);
    fetch('/order/cancel', {
      method: 'put',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id,orderId, user,price,cancelReason})
    }).then(res => res.json()).then(data => {
      console.log(data);
      if (data.set) {
        status.innerHTML = 'cancelled';
        status.classList.add('text-danger')
        btn.style.pointerEvents = 'none';
        btn.style.opacity = 0.5;
      }
      if (data.issue) {
        Swal.fire({
          icon: "error",
          title: "Oops...",
          text: "Something went wrong!",

        });
      }
    })
  }

