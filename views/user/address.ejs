<%- include('../layout/header.ejs') -%>
  <link rel="stylesheet" href="css/mycss/profile.css">
  </head>

  <body>

    <%- include('../layout/nave.ejs') -%>
      <nav aria-label="breadcrumb" class="breadcrumb-nav mb-3">
        <div class="container">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">My Account</li>
          </ol>
        </div><!-- End .container -->
      </nav>
      <br>



      <section class="">
        <div class="container-fluid  py-5 h-100 position-relative ">
          <div class="row d-flex    align-items-start  h-100" style="gap: 10rem;">
            <%- include('../layout/profileSidebar', { activePage: 'address' }) %>
            <aside class="col col-lg-8 mb-4 mb-lg-0">
              <!-- Address Header & Add Button -->
              <div class="amz-card" style="margin-bottom: 2rem;">
                <div class="amz-card-header" style="background: #fff; display: flex; justify-content: space-between; align-items: center; border-radius: 8px;">
                  <h3 style="margin: 0; font-size: 1.25rem; font-weight: 700;">Your Saved Addresses</h3>
                  <button type="button" class="amz-btn amz-btn-primary" onclick="openAddModal('<%= locals.login %>')">
                    <i class="fas fa-plus me-2"></i> Add New Address
                  </button>
                </div>
              </div>

              <!-- Address Grid -->
              <div class="amz-grid-custom hh">
                <% if(locals.address && address.address && address.address.length > 0) { %>
                  <% address.address.forEach((e, i)=>{ %>
                  <article class="amz-address-card <%= user.addressId+'hh' == e._id+'hh' ? 'active-address' : '' %>" id="card<%= e._id %>">
                    <div class="card-header border-bottom pb-2 mb-3">
                      <div class="d-flex align-items-center gap-2">
                        <div class="custom-radio">
                          <input type="checkbox" name="group1" class="checkbox-group" id="radio_<%= e._id %>" <%= user.addressId+'hh' == e._id+'hh' ? 'checked' : '' %> onchange="change('<%= e._id %>','<%= locals.login%>')">
                          <label for="radio_<%= e._id %>"></label>
                        </div>
                        <h3 class="card-title" style="font-weight: 700; margin: 0; font-size: 1.1rem;"><%= e.name %></h3>
                      </div>
                      <button type="button" onclick="dele('<%= e._id %>','<%=address.userId%>')" class="delete-btn btn text-danger p-0" title="Delete Address"><i class="fas fa-trash"></i></button>
                    </div>
                    <div class="card-body p-0">
                      <p class="mb-1"><i class="fas fa-map-marker-alt text-muted me-2"></i> <strong>Address:</strong> <%= e.name %></p>
                      <p class="mb-1"><i class="fas fa-city text-muted me-2"></i> <strong>City:</strong> <%= e.city %></p>
                      <p class="mb-1"><i class="fas fa-map-marked-alt text-muted me-2"></i> <strong>State:</strong> <%= e.state %></p>
                      <p class="mb-0"><i class="fas fa-map-pin text-muted me-2"></i> <strong>Pincode:</strong> <%= e.pincode %></p>
                    </div>
                  </article>
                  <% }) %>
                <% } else { %>
                  <div class="w-100 text-center py-5">
                    <i class="fas fa-map-marked-alt fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">No addresses saved yet.</h4>
                  </div>
                <% } %>
              </div>
            </aside>
          </div>

        </div>
      </section>
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"/>

  <!-- Address Modal -->
  <div id="addAddressModal" class="modal">
    <div class="modal-content">
      <span class="close" onclick="closeAddModal()">&times;</span>
      <h2 style="font-weight: 700; font-size: 1.4rem; color: #333; margin-bottom: 24px;">Add New Address</h2>
      <form id="addAddressForm" method="post">
        <div class="mb-3">
          <label for="inpName" class="form-label" style="font-weight: 600;">Address Name / Street</label>
          <input type="text" id="inpName" class="form-control" name="name" placeholder="E.g., Home, Office" required>
          <p class="text-danger mt-1 fs-6" id="nameAlert" style="font-size: 0.85rem !important;"></p>
        </div>
        <div class="mb-3">
          <label class="form-label" style="font-weight: 600;">City</label>
          <input type="text" id="inpCity" class="form-control" name="city" placeholder="City Name" required>
          <p class="text-danger mt-1" id="cityAlert" style="font-size: 0.85rem; display: none; margin-bottom: 0;">City cannot be empty.</p>
        </div>
        <div class="mb-3">
          <label class="form-label" style="font-weight: 600;">State</label>
          <input type="text" id="inpState" class="form-control" name="state" placeholder="State Name" required>
          <p class="text-danger mt-1" id="stateAlert" style="font-size: 0.85rem; display: none; margin-bottom: 0;">State cannot be empty.</p>
        </div>
        <div class="mb-3">
          <label class="form-label" style="font-weight: 600;">Pincode (6 digits)</label>
          <input type="number" id="inpPincode" class="form-control" min="100000" pattern="\d{6}" title="Please enter a 6-digit number." name="pincode" placeholder="Pincode" required>
          <p class="text-danger mt-1" id="pincodeAlert" style="font-size: 0.85rem; display: none; margin-bottom: 0;">Pincode cannot be empty.</p>
        </div>
        <div class="d-flex justify-content-end gap-2 mt-4">
          <button type="button" class="amz-btn amz-btn-secondary" onclick="closeAddModal()">Cancel</button>
          <button type="submit" id="submitAddressBtn" class="amz-btn amz-btn-primary">Save Address</button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .amz-card { background: #fff; border: 1px solid #eaeaec; border-radius: 8px; box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04); overflow: hidden; }
    .amz-card-header { padding: 16px 20px; }
    .amz-btn { padding: 10px 15px; font-size: 0.85rem; font-weight: 600; border-radius: 6px; text-align: center; cursor: pointer; transition: all 0.2s ease; border: 1px solid transparent; display: inline-flex; justify-content: center; align-items: center; }
    .amz-btn-primary { background-color: #c96; color: #fff; }
    .amz-btn-primary:hover { background-color: #b85; color: #fff; box-shadow: 0 4px 8px rgba(204, 153, 102, 0.3); }
    .amz-btn-secondary { background-color: #fff; border-color: #d5d5d5; color: #333; }
    .amz-btn-secondary:hover { background-color: #f7f7f8; border-color: #c96; color: #c96; }

    .amz-grid-custom { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; padding: 10px 0; }
    
    .amz-address-card { background: #fff; border: 1px solid #eaeaec; border-radius: 8px; padding: 20px; transition: all 0.2s ease; position: relative; }
    .amz-address-card:hover { box-shadow: 0 6px 16px rgba(0,0,0,0.08); transform: translateY(-2px); }
    .amz-address-card.active-address { border: 2px solid #c96; box-shadow: 0 4px 12px rgba(204, 153, 102, 0.15); background: #faf8f5;}
    
    .custom-radio { position: relative; display: inline-block; width: 18px; height: 18px; }
    .custom-radio input { opacity: 0; width: 0; height: 0; position: absolute; }
    .custom-radio label { position: absolute; top: 0; left: 0; width: 18px; height: 18px; background: #fff; border: 2px solid #ccc; border-radius: 50%; cursor: pointer; }
    .custom-radio input:checked + label { border-color: #c96; }
    .custom-radio input:checked + label::after { content: ''; position: absolute; top: 3px; left: 3px; width: 8px; height: 8px; background: #c96; border-radius: 50%; }

    .card-header { display: flex; justify-content: space-between; align-items: center; border-bottom: none; background: transparent; }
    
    /* Modal */
    .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); }
    .modal-content { background-color: #fff; margin: 10vh auto; padding: 30px; border: 1px solid #eaeaec; width: 90%; max-width: 450px; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.15); position: relative; animation: slideDownFade 0.4s ease; max-height: 80vh; overflow-y: auto; }
    @keyframes slideDownFade { from { opacity: 0; transform: translateY(-30px); } to { opacity: 1; transform: translateY(0); } }
    .close { position: absolute; top: 15px; right: 20px; color: #999; font-size: 24px; font-weight: bold; cursor: pointer; transition: color 0.2s; line-height: 1; text-decoration: none; }
    .close:hover { color: #c96; }
    .modal .form-control { border-radius: 6px; border: 1px solid #ccc; padding: 10px 12px; transition: border-color 0.2s; }
    .modal .form-control:focus { border-color: #c96; box-shadow: 0 0 0 3px rgba(204,153,102,0.15); outline: none; }
  </style>

  <script>
    const modal = document.getElementById('addAddressModal');
    const form = document.getElementById('addAddressForm');
    const inpName = document.getElementById('inpName');
    const nameAlert = document.getElementById('nameAlert');
    const submitBtn = document.getElementById('submitAddressBtn');
    let currentUserId = '';

    function openAddModal(userId) {
      currentUserId = userId;
      form.action = '/address?id=' + userId;
      form.reset();
      
      // Reset validation indicators
      inpName.style.borderColor = "#ccc";
      nameAlert.textContent = '';
      document.getElementById('inpCity').style.borderColor = "#ccc";
      document.getElementById('cityAlert').style.display = 'none';
      document.getElementById('inpState').style.borderColor = "#ccc";
      document.getElementById('stateAlert').style.display = 'none';
      document.getElementById('inpPincode').style.borderColor = "#ccc";
      document.getElementById('pincodeAlert').style.display = 'none';

      submitBtn.style.pointerEvents = 'all';
      submitBtn.style.opacity = 1;
      
      modal.style.display = 'block';
    }

    function closeAddModal() {
      modal.style.display = 'none';
    }

    // Close when clicking outside modal
    window.onclick = function(event) {
      if (event.target == modal) {
        closeAddModal();
      }
    }

    // Name Exists Validation
    inpName.addEventListener('input', function() {
      if(!currentUserId) return;
      
      fetch('/address', {
        method: 'PUT',
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ val: this.value, id: currentUserId })
      })
      .then(res => res.json())
      .then(data => {
        if (data.exists) {
          inpName.style.borderColor = "red";
          nameAlert.textContent = 'This address name already exists.';
          submitBtn.style.pointerEvents = 'none';
          submitBtn.style.opacity = 0.5;
        }
        if (data.note) {
          inpName.style.borderColor = "#c96";
          nameAlert.textContent = '';
          submitBtn.style.pointerEvents = 'all';
          submitBtn.style.opacity = 1;
        }
      });
    });

    // Validate Address Submission
    form.addEventListener('submit', function(e) {
      const cityInput = document.getElementById('inpCity');
      const stateInput = document.getElementById('inpState');
      const pincodeInput = document.getElementById('inpPincode');
      
      const cityAlert = document.getElementById('cityAlert');
      const stateAlert = document.getElementById('stateAlert');
      const pincodeAlert = document.getElementById('pincodeAlert');
      
      let isValid = true;
      
      if(!inpName.value.trim()) {
        nameAlert.textContent = 'Address name cannot be empty.';
        inpName.style.borderColor = "red";
        isValid = false;
      }
      
      if(!cityInput.value.trim()) {
        cityAlert.style.display = 'block';
        cityInput.style.borderColor = "red";
        isValid = false;
      } else {
        cityAlert.style.display = 'none';
        cityInput.style.borderColor = "#ccc";
      }

      if(!stateInput.value.trim()) {
        stateAlert.style.display = 'block';
        stateInput.style.borderColor = "red";
        isValid = false;
      } else {
        stateAlert.style.display = 'none';
        stateInput.style.borderColor = "#ccc";
      }
      
      if(!pincodeInput.value.trim() || pincodeInput.value.length !== 6) {
        pincodeAlert.style.display = 'block';
        pincodeInput.style.borderColor = "red";
        isValid = false;
      } else {
        pincodeAlert.style.display = 'none';
        pincodeInput.style.borderColor = "#ccc";
      }
      
      if(!isValid) {
        e.preventDefault();
        return false;
      }
    });

    // Delete Address with Confirmation
    function dele(id, uid) {
      Swal.fire({
        title: "Delete Address?",
        text: "Are you sure you want to remove this address?",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#fc4b6c",
        cancelButtonColor: "#888",
        confirmButtonText: "Yes, delete it!"
      }).then((result) => {
        if (result.isConfirmed) {
          const card = document.getElementById(`card${id}`);
          fetch('/address', {
            method: 'delete',
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id, uid })
          })
          .then(res => res.json())
          .then(data => {
            if (data.result) {
              card.style.transition = "all 0.3s ease";
              card.style.opacity = "0";
              card.style.transform = "scale(0.95)";
              setTimeout(() => {
                card.remove();
                const grid = document.querySelector('.amz-grid-custom');
                if(grid && grid.querySelectorAll('.amz-address-card').length === 0) {
                  grid.innerHTML = `<div class="w-100 text-center py-5">
                    <i class="fas fa-map-marked-alt fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">No addresses saved yet.</h4>
                  </div>`;
                }
              }, 300);
              
              const Toast = Swal.mixin({
                toast: true,
                position: "top-end",
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true
              });
              Toast.fire({
                icon: "success",
                title: "Address deleted successfully"
              });
            }
          });
        }
      });
    }

    // Set Default Address
    function change(id, uid) {
      fetch('/address/default', {
        method: 'PUT',
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id, uid })
      })
      .then(res => res.json())
      .then(data => {
        if(data.done) {
          // Visual update of active card
          document.querySelectorAll('.amz-address-card').forEach(c => c.classList.remove('active-address'));
          document.getElementById('card' + id).classList.add('active-address');
          
          document.querySelectorAll('.checkbox-group').forEach(checkbox => {
            if (checkbox.id !== 'radio_' + id) {
              checkbox.checked = false;
            }
          });
        }
      });
    }
  </script>

